{
  "scopeName": "source.tryzub",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#functions" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.tryzub", "match": "///.*$" },
        { "name": "comment.line.double-slash.tryzub", "match": "//.*$" },
        { "name": "comment.block.tryzub", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.tryzub",
          "begin": "褎\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.tryzub", "match": "\\\\." },
            { "name": "variable.other.interpolation.tryzub", "match": "\\{[^}]+\\}" }
          ]
        },
        {
          "name": "string.quoted.double.tryzub",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.tryzub", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.single.tryzub",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.tryzub", "match": "\\\\." }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.float.tryzub", "match": "\\b\\d+\\.\\d+\\b" },
        { "name": "constant.numeric.hex.tryzub", "match": "\\b0x[0-9a-fA-F]+\\b" },
        { "name": "constant.numeric.binary.tryzub", "match": "\\b0b[01]+\\b" },
        { "name": "constant.numeric.integer.tryzub", "match": "\\b\\d+\\b" }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.tryzub",
          "match": "\\b(褟泻褖芯|褨薪邪泻褕械|锌芯泻懈|写谢褟|胁|胁褨写|写芯|蟹褨褋褌邪胁懈褌懈|锌芯胁械褉薪褍褌懈|锌械褉械褉胁邪褌懈|锌褉芯写芯胁卸懈褌懈|褋锌褉芯斜褍胁邪褌懈|蟹谢芯胁懈褌懈|薪邪褉械褕褌褨|褔械泻邪褌懈|胁褨写写邪褌懈|褨屑锌芯褉褌|褟泻|蟹)\\b"
        },
        {
          "name": "keyword.declaration.tryzub",
          "match": "\\b(褎褍薪泻褑褨褟|蟹屑褨薪薪邪|褋褌邪谢邪|褋褌褉褍泻褌褍褉邪|褌懈锌|褌褉械泄褌|褉械邪谢褨蟹邪褑褨褟|屑芯写褍谢褜|邪褋懈薪褏褉芯薪薪邪|锌褍斜谢褨褔薪懈泄|锌褉懈胁邪褌薪懈泄)\\b"
        },
        {
          "name": "keyword.other.tryzub",
          "match": "\\b(写褉褍泻|褋械斜械|褑械|锌芯褌褨泻|胁褋械|锌械褉械谐芯薪懈|泻邪薪邪谢)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.tryzub",
          "match": "\\b(褑谢8|褑谢16|褑谢32|褑谢64|写褉斜32|写褉斜64|谢芯谐|褌褏褌|褋懈屑|褔褋8|褔褋16|褔褋32|褔褋64)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        { "name": "constant.language.tryzub", "match": "\\b(褨褋褌懈薪邪|褏懈斜邪|薪褍谢褜|袧褨褔芯谐芯)\\b" },
        { "name": "support.function.builtin.tryzub", "match": "\\b(袛械褟泻懈泄|校褋锌褨褏|袩芯屑懈谢泻邪)\\b" }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.tryzub",
          "match": "\\b([邪-褟袗-携褨袉褩袊褦袆覒覑a-zA-Z_][邪-褟袗-携褨袉褩袊褦袆覒覑a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.tryzub", "match": "\\|>|->|=>|==|!=|<=|>=|\\+=|-=|\\*=|/=|&&|\\|\\||!" },
        { "name": "keyword.operator.tryzub", "match": "[+\\-*/%<>=]" }
      ]
    }
  }
}
