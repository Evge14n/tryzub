{
  "name": "tryzub-lang",
  "displayName": "Тризуб — Українська мова програмування",
  "description": "Syntax highlighting, LSP, snippets and code intelligence for Tryzub (Тризуб) programming language",
  "version": "1.0.0",
  "publisher": "Evge14n",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Evge14n/tryzub"
  },
  "engines": { "vscode": "^1.80.0" },
  "categories": ["Programming Languages", "Snippets", "Linters", "Formatters"],
  "keywords": ["tryzub", "тризуб", "ukrainian", "programming language", "ukraine"],
  "icon": "icon.png",
  "activationEvents": ["onLanguage:tryzub"],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "tryzub",
        "aliases": ["Тризуб", "Tryzub", "tryzub"],
        "extensions": [".тризуб", ".tryzub"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icon.png",
          "dark": "./icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "tryzub",
        "scopeName": "source.tryzub",
        "path": "./syntaxes/tryzub.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "tryzub",
        "path": "./snippets/tryzub.json"
      }
    ],
    "configuration": {
      "title": "Тризуб",
      "properties": {
        "tryzub.lsp.path": {
          "type": "string",
          "default": "tryzub",
          "description": "Path to the Tryzub executable for LSP server"
        }
      }
    }
  }
}
