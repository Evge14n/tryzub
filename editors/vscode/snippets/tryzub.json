{
  "Функція": {
    "prefix": "функція",
    "body": ["функція ${1:назва}(${2:параметри}) {", "\t${0}", "}"],
    "description": "Нова функція"
  },
  "Функція з типами": {
    "prefix": "функціятип",
    "body": ["функція ${1:назва}(${2:парам}: ${3:цл64}) -> ${4:цл64} {", "\t${0}", "}"],
    "description": "Функція з типізованими параметрами"
  },
  "Асинхронна функція": {
    "prefix": "асинх",
    "body": ["асинхронна функція ${1:назва}() {", "\t${0}", "}"],
    "description": "Асинхронна функція"
  },
  "Головна функція": {
    "prefix": "головна",
    "body": ["функція головна() {", "\t${0}", "}"],
    "description": "Головна функція програми"
  },
  "Структура": {
    "prefix": "структура",
    "body": ["структура ${1:Назва} {", "\t${2:поле}: ${3:тип}", "}"],
    "description": "Нова структура"
  },
  "Структура з методами": {
    "prefix": "структурараз",
    "body": ["структура ${1:Назва} {", "\t${2:поле}: ${3:тип}", "}", "", "реалізація ${1} {", "\tфункція ${4:метод}(себе) {", "\t\t${0}", "\t}", "}"],
    "description": "Структура з реалізацією"
  },
  "Перелік": {
    "prefix": "перелік",
    "body": ["перелік ${1:Назва} {", "\t${2:Варіант1},", "\t${3:Варіант2}", "}"],
    "description": "Новий перелік (enum)"
  },
  "Якщо": {
    "prefix": "якщо",
    "body": ["якщо ${1:умова} {", "\t${0}", "}"],
    "description": "Умовний блок"
  },
  "Якщо/інакше": {
    "prefix": "якщоінакше",
    "body": ["якщо ${1:умова} {", "\t${2}", "} інакше {", "\t${0}", "}"],
    "description": "Умовний блок з else"
  },
  "Для": {
    "prefix": "для",
    "body": ["для ${1:елемент} в ${2:колекція} {", "\t${0}", "}"],
    "description": "Цикл for-in"
  },
  "Для діапазон": {
    "prefix": "длядіап",
    "body": ["для ${1:і} від ${2:0} до ${3:10} {", "\t${0}", "}"],
    "description": "Цикл for з діапазоном"
  },
  "Поки": {
    "prefix": "поки",
    "body": ["поки ${1:умова} {", "\t${0}", "}"],
    "description": "Цикл while"
  },
  "Зіставити": {
    "prefix": "зіставити",
    "body": ["зіставити ${1:вираз} {", "\t${2:зразок} => ${3:результат},", "\t_ => ${0}", "}"],
    "description": "Pattern matching"
  },
  "Трейт": {
    "prefix": "трейт",
    "body": ["трейт ${1:Назва} {", "\tфункція ${2:метод}(себе)${0}", "}"],
    "description": "Новий трейт"
  },
  "Реалізація трейту": {
    "prefix": "реалтрейт",
    "body": ["реалізація ${1:Трейт} для ${2:Тип} {", "\tфункція ${3:метод}(себе) {", "\t\t${0}", "\t}", "}"],
    "description": "Реалізація трейту для типу"
  },
  "Реалізація": {
    "prefix": "реалізація",
    "body": ["реалізація ${1:Тип} {", "\tфункція ${2:метод}(себе) {", "\t\t${0}", "\t}", "}"],
    "description": "Реалізація методів"
  },
  "Модуль": {
    "prefix": "модуль",
    "body": ["модуль ${1:назва} {", "\t${0}", "}"],
    "description": "Новий модуль"
  },
  "Спробувати": {
    "prefix": "спробувати",
    "body": ["спробувати {", "\t${1}", "} зловити помилка {", "\tдрук(помилка)", "\t${0}", "}"],
    "description": "Try/catch блок"
  },
  "Друк": {
    "prefix": "друк",
    "body": ["друк(${0})"],
    "description": "Вивести в консоль"
  },
  "Друк формат": {
    "prefix": "друкф",
    "body": ["друк(ф\"${1:текст} {${2:змінна}}\")"],
    "description": "Друк з форматованим рядком"
  },
  "Тест": {
    "prefix": "тест",
    "body": ["тест \"${1:назва тесту}\" {", "\t${0}", "}"],
    "description": "Новий тест"
  },
  "Імпорт": {
    "prefix": "імпорт",
    "body": ["імпорт ${1:модуль}"],
    "description": "Імпортувати модуль"
  },
  "Змінна": {
    "prefix": "змінна",
    "body": ["змінна ${1:назва} = ${0}"],
    "description": "Оголосити змінну"
  },
  "Стала": {
    "prefix": "стала",
    "body": ["стала ${1:НАЗВА} = ${0}"],
    "description": "Оголосити константу"
  },
  "Лямбда": {
    "prefix": "лямбда",
    "body": ["|${1:парам}| ${0}"],
    "description": "Лямбда-функція"
  }
}
