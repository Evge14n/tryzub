{
  "Функція": {
    "prefix": "функція",
    "body": ["функція ${1:назва}(${2:параметри}) {", "\t${0}", "}"],
    "description": "Нова функція"
  },
  "Головна функція": {
    "prefix": "головна",
    "body": ["функція головна() {", "\t${0}", "}"],
    "description": "Головна функція програми"
  },
  "Структура": {
    "prefix": "структура",
    "body": ["структура ${1:Назва} {", "\t${2:поле}: ${3:тип}", "}"],
    "description": "Нова структура"
  },
  "Якщо": {
    "prefix": "якщо",
    "body": ["якщо (${1:умова}) {", "\t${0}", "}"],
    "description": "Умовний блок"
  },
  "Якщо/інакше": {
    "prefix": "якщоінакше",
    "body": ["якщо (${1:умова}) {", "\t${2}", "} інакше {", "\t${0}", "}"],
    "description": "Умовний блок з else"
  },
  "Для": {
    "prefix": "для",
    "body": ["для (${1:і} в ${2:масив}) {", "\t${0}", "}"],
    "description": "Цикл for-in"
  },
  "Поки": {
    "prefix": "поки",
    "body": ["поки (${1:умова}) {", "\t${0}", "}"],
    "description": "Цикл while"
  },
  "Зіставити": {
    "prefix": "зіставити",
    "body": ["зіставити ${1:вираз} {", "\t${2:зразок} => ${3:результат},", "\t_ => ${0}", "}"],
    "description": "Pattern matching"
  },
  "Трейт": {
    "prefix": "трейт",
    "body": ["трейт ${1:Назва} {", "\tфункція ${2:метод}(себе)${0}", "}"],
    "description": "Новий трейт"
  },
  "Реалізація": {
    "prefix": "реалізація",
    "body": ["реалізація ${1:Тип} {", "\tфункція ${2:метод}(себе) {", "\t\t${0}", "\t}", "}"],
    "description": "Реалізація методів"
  },
  "Модуль": {
    "prefix": "модуль",
    "body": ["модуль ${1:назва} {", "\t${0}", "}"],
    "description": "Новий модуль"
  },
  "Спробувати": {
    "prefix": "спробувати",
    "body": ["спробувати {", "\t${1}", "} зловити (помилка) {", "\t${0}", "}"],
    "description": "Try/catch блок"
  },
  "Друк": {
    "prefix": "друк",
    "body": ["друк(${0})"],
    "description": "Вивести в консоль"
  },
  "Тест": {
    "prefix": "тест",
    "body": ["тест \"${1:назва тесту}\" {", "\t${0}", "}"],
    "description": "Новий тест"
  }
}
