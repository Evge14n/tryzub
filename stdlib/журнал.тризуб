// Стандартна бібліотека мови Тризуб
// Модуль: журнал — логування

модуль журнал {
    змінна ВІДЛАГОДЖЕННЯ = 0
    змінна ІНФО = 1
    змінна ПОПЕРЕДЖЕННЯ = 2
    змінна ПОМИЛКА = 3
    змінна КРИТИЧНО = 4

    змінна _рівень = 1

    функція встановити_рівень(рівень) {
        _рівень = рівень
    }

    функція _мітка_часу() {
        повернути час_зараз()
    }

    функція _назва_рівня(рівень) {
        якщо (рівень == 0) { повернути "ВІДЛАГОДЖЕННЯ" }
        якщо (рівень == 1) { повернути "ІНФО" }
        якщо (рівень == 2) { повернути "ПОПЕРЕДЖЕННЯ" }
        якщо (рівень == 3) { повернути "ПОМИЛКА" }
        якщо (рівень == 4) { повернути "КРИТИЧНО" }
        повернути "НЕВІДОМО"
    }

    функція _записати(рівень, повідомлення) {
        якщо (рівень >= _рівень) {
            друк("[" + _назва_рівня(рівень) + "] " + повідомлення)
        }
    }

    функція відлагодження(повідомлення) { _записати(0, повідомлення) }
    функція інфо(повідомлення) { _записати(1, повідомлення) }
    функція попередження(повідомлення) { _записати(2, повідомлення) }
    функція помилка(повідомлення) { _записати(3, повідомлення) }
    функція критично(повідомлення) { _записати(4, повідомлення) }
}
