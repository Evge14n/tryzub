структура МітьЧасу {
    секунди: цл64,
    наносекунди: цл64
}

структура Дата {
    рік: цл32,
    місяць: цл32,
    день: цл32
}

структура ЧасДоби {
    години: цл32,
    хвилини: цл32,
    секунди: цл32
}

структура ДатаЧас {
    дата: Дата,
    час: ЧасДоби
}

структура Тривалість {
    секунди: цл64,
    наносекунди: цл64
}

// ════════════════════════════════════════════════════════════════════
// Реалізації
// ════════════════════════════════════════════════════════════════════

реалізація Тривалість {
    функція з_секунд(сек: цл64) -> Тривалість {
        повернути Тривалість { секунди: сек, наносекунди: 0 }
    }

    функція з_мілісекунд(мс: цл64) -> Тривалість {
        повернути Тривалість {
            секунди: мс / 1000,
            наносекунди: (мс % 1000) * 1000000
        }
    }

    функція з_хвилин(хв: цл64) -> Тривалість {
        повернути Тривалість { секунди: хв * 60, наносекунди: 0 }
    }

    функція з_годин(год: цл64) -> Тривалість {
        повернути Тривалість { секунди: год * 3600, наносекунди: 0 }
    }

    функція з_днів(днів: цл64) -> Тривалість {
        повернути Тривалість { секунди: днів * 86400, наносекунди: 0 }
    }

    функція всього_секунд(себе) -> дрб64 {
        повернути себе.секунди + себе.наносекунди / 1000000000.0
    }

    функція всього_мілісекунд(себе) -> цл64 {
        повернути себе.секунди * 1000 + себе.наносекунди / 1000000
    }
}

реалізація Дата {
    функція нова(рік: цл32, місяць: цл32, день: цл32) -> Результат<Дата, тхт> {
        якщо (місяць < 1 || місяць > 12) {
            повернути Помилка("Невірний місяць")
        }
        якщо (день < 1 || день > 31) {
            повернути Помилка("Невірний день")
        }
        повернути Успіх(Дата { рік: рік, місяць: місяць, день: день })
    }

    функція високосний(рік: цл32) -> лог {
        повернути (рік % 4 == 0 && рік % 100 != 0) || (рік % 400 == 0)
    }

    функція днів_у_місяці(себе) -> цл32 {
        зіставити себе.місяць {
            1 | 3 | 5 | 7 | 8 | 10 | 12 => 31,
            4 | 6 | 9 | 11 => 30,
            2 => якщо (Дата.високосний(себе.рік)) { 29 } інакше { 28 },
            _ => 0
        }
    }

    функція день_тижня(себе) -> тхт {
        // Алгоритм Зеллера
        змінна р = себе.рік
        змінна м = себе.місяць
        якщо (м < 3) {
            м += 12
            р -= 1
        }
        змінна день = (себе.день + (13 * (м + 1)) / 5 + р + р / 4 - р / 100 + р / 400) % 7
        зіставити день {
            0 => "Субота",
            1 => "Неділя",
            2 => "Понеділок",
            3 => "Вівторок",
            4 => "Середа",
            5 => "Четвер",
            6 => "П'ятниця",
            _ => "Невідомо"
        }
    }

    функція форматувати(себе) -> тхт {
        змінна назва_місяця = зіставити себе.місяць {
            1 => "січня", 2 => "лютого", 3 => "березня",
            4 => "квітня", 5 => "травня", 6 => "червня",
            7 => "липня", 8 => "серпня", 9 => "вересня",
            10 => "жовтня", 11 => "листопада", 12 => "грудня",
            _ => "невідомо"
        }
        повернути ф"{себе.день} {назва_місяця} {себе.рік}"
    }
}

