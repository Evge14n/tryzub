// Стандартна бібліотека: Випадкові числа

модуль випадкове {
    змінна _зерно = 42

    функція встановити_зерно(з) {
        _зерно = з
    }

    функція ціле(мін, макс) {
        _зерно = (_зерно * 1103515245 + 12345) % 2147483648
        повернути мін + _зерно % (макс - мін + 1)
    }

    функція дробове() {
        _зерно = (_зерно * 1103515245 + 12345) % 2147483648
        повернути _зерно / 2147483648.0
    }

    функція вибрати(масив) {
        змінна і = ціле(0, довжина(масив) - 1)
        повернути масив[і]
    }

    функція перемішати(масив) {
        змінна результат = масив
        змінна і = довжина(результат) - 1
        поки (і > 0) {
            змінна й = ціле(0, і)
            змінна тимч = результат[і]
            результат[і] = результат[й]
            результат[й] = тимч
            і = і - 1
        }
        повернути результат
    }
}
