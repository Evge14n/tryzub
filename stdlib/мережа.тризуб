// Стандартна бібліотека: Мережа

модуль мережа {
    функція отримати(url) {
        повернути http_отримати(url)
    }

    функція надіслати(url, дані) {
        повернути http_надіслати(url, дані)
    }

    функція url_розібрати(url) {
        змінна результат = словник()
        змінна частини = url.розділити("://")
        якщо (довжина(частини) >= 2) {
            результат["протокол"] = частини[0]
            змінна решта = частини[1]
            змінна шлях_частини = решта.розділити("/")
            результат["хост"] = шлях_частини[0]
            якщо (довжина(шлях_частини) > 1) {
                результат["шлях"] = "/" + решта.розділити(шлях_частини[0])[1]
            } інакше {
                результат["шлях"] = "/"
            }
        }
        повернути результат
    }
}
