// Стандартна бібліотека мови Тризуб
// Модуль: тестування

модуль тестування {
    змінна _пройшло = 0
    змінна _провалено = 0

    функція перевірити_рівність(а, б, повідомлення) {
        якщо (а == б) {
            _пройшло = _пройшло + 1
        } інакше {
            _провалено = _провалено + 1
            друк("[ПРОВАЛ] " + повідомлення + ": очікувалось " + ціле_в_рядок(б) + ", отримано " + ціле_в_рядок(а))
        }
    }

    функція перевірити_нерівність(а, б) {
        якщо (а != б) {
            _пройшло = _пройшло + 1
        } інакше {
            _провалено = _провалено + 1
            друк("[ПРОВАЛ] значення не мають бути рівними: " + ціле_в_рядок(а))
        }
    }

    функція перевірити_істина(умова, повідомлення) {
        якщо (умова) {
            _пройшло = _пройшло + 1
        } інакше {
            _провалено = _провалено + 1
            друк("[ПРОВАЛ] " + повідомлення + ": очікувалось істина")
        }
    }

    функція перевірити_хиба(умова, повідомлення) {
        якщо (!умова) {
            _пройшло = _пройшло + 1
        } інакше {
            _провалено = _провалено + 1
            друк("[ПРОВАЛ] " + повідомлення + ": очікувалось хиба")
        }
    }

    функція перевірити_містить(масив, елемент) {
        змінна знайдено = хиба
        для (е в масив) {
            якщо (е == елемент) { знайдено = істина }
        }
        якщо (знайдено) {
            _пройшло = _пройшло + 1
        } інакше {
            _провалено = _провалено + 1
            друк("[ПРОВАЛ] масив не містить елемент")
        }
    }

    функція перевірити_тип(значення, тип) {
        якщо (тип_значення(значення) == тип) {
            _пройшло = _пройшло + 1
        } інакше {
            _провалено = _провалено + 1
            друк("[ПРОВАЛ] очікувався тип '" + тип + "', отримано '" + тип_значення(значення) + "'")
        }
    }

    функція результат() {
        друк("")
        друк("Результати тестування:")
        друк("  Пройшло: " + ціле_в_рядок(_пройшло))
        друк("  Провалено: " + ціле_в_рядок(_провалено))
        друк("  Всього: " + ціле_в_рядок(_пройшло + _провалено))
        якщо (_провалено == 0) {
            друк("  Статус: ВСІ ТЕСТИ ПРОЙШЛИ")
        } інакше {
            друк("  Статус: Є ПРОВАЛИ")
        }
    }
}
