// ════════════════════════════════════════════════════════════════════
// Вектор — динамічний масив
// ════════════════════════════════════════════════════════════════════

структура Вектор<Т> {
    дані: [Т],
    розмір: цл64,
    ємність: цл64
}

реалізація Вектор<Т> {
    функція новий() -> Вектор<Т> {
        повернути Вектор { дані: [], розмір: 0, ємність: 0 }
    }

    функція з_масиву(масив: [Т]) -> Вектор<Т> {
        повернути Вектор {
            дані: масив,
            розмір: довжина(масив),
            ємність: довжина(масив)
        }
    }

    функція додати(себе, елемент: Т) {
        себе.дані = себе.дані + [елемент]
        себе.розмір += 1
    }

    функція отримати(себе, індекс: цл64) -> Опція<Т> {
        якщо (індекс >= 0 && індекс < себе.розмір) {
            повернути Деякий(себе.дані[індекс])
        }
        повернути Нічого
    }

    функція видалити(себе, індекс: цл64) -> Опція<Т> {
        якщо (індекс < 0 || індекс >= себе.розмір) {
            повернути Нічого
        }
        змінна елемент = себе.дані[індекс]
        // Зсуваємо елементи
        змінна нові_дані = []
        для (і від 0 до себе.розмір) {
            якщо (і != індекс) {
                нові_дані = нові_дані + [себе.дані[і]]
            }
        }
        себе.дані = нові_дані
        себе.розмір -= 1
        повернути Деякий(елемент)
    }

    функція довжина(себе) -> цл64 {
        повернути себе.розмір
    }

    функція пусто(себе) -> лог {
        повернути себе.розмір == 0
    }

    функція містить(себе, елемент: Т) -> лог {
        для (і від 0 до себе.розмір) {
            якщо (себе.дані[і] == елемент) {
                повернути істина
            }
        }
        повернути хиба
    }

    функція очистити(себе) {
        себе.дані = []
        себе.розмір = 0
    }

    функція перший(себе) -> Опція<Т> {
        якщо (себе.розмір > 0) {
            повернути Деякий(себе.дані[0])
        }
        повернути Нічого
    }

    функція останній(себе) -> Опція<Т> {
        якщо (себе.розмір > 0) {
            повернути Деякий(себе.дані[себе.розмір - 1])
        }
        повернути Нічого
    }

    функція фільтрувати(себе, предикат: функція(Т) -> лог) -> Вектор<Т> {
        змінна результат = Вектор.новий()
        для (і від 0 до себе.розмір) {
            якщо (предикат(себе.дані[і])) {
                результат.додати(себе.дані[і])
            }
        }
        повернути результат
    }

    функція перетворити<У>(себе, ф: функція(Т) -> У) -> Вектор<У> {
        змінна результат = Вектор.новий()
        для (і від 0 до себе.розмір) {
            результат.додати(ф(себе.дані[і]))
        }
        повернути результат
    }

    функція згорнути<А>(себе, початок: А, ф: функція(А, Т) -> А) -> А {
        змінна акумулятор = початок
        для (і від 0 до себе.розмір) {
            акумулятор = ф(акумулятор, себе.дані[і])
        }
        повернути акумулятор
    }
}

// ════════════════════════════════════════════════════════════════════
// Словник — асоціативний масив (хеш-таблиця)
// ════════════════════════════════════════════════════════════════════

структура Словник<К, В> {
    ключі: [К],
    значення: [В],
    розмір: цл64
}

реалізація Словник<К, В> {
    функція новий() -> Словник<К, В> {
        повернути Словник { ключі: [], значення: [], розмір: 0 }
    }

    функція встановити(себе, ключ: К, значення: В) {
        // Перевіряємо чи ключ вже існує
        для (і від 0 до себе.розмір) {
            якщо (себе.ключі[і] == ключ) {
                себе.значення[і] = значення
                повернути
            }
        }
        себе.ключі = себе.ключі + [ключ]
        себе.значення = себе.значення + [значення]
        себе.розмір += 1
    }

    функція отримати(себе, ключ: К) -> Опція<В> {
        для (і від 0 до себе.розмір) {
            якщо (себе.ключі[і] == ключ) {
                повернути Деякий(себе.значення[і])
            }
        }
        повернути Нічого
    }

    функція містить(себе, ключ: К) -> лог {
        для (і від 0 до себе.розмір) {
            якщо (себе.ключі[і] == ключ) {
                повернути істина
            }
        }
        повернути хиба
    }

    функція видалити(себе, ключ: К) -> Опція<В> {
        для (і від 0 до себе.розмір) {
            якщо (себе.ключі[і] == ключ) {
                змінна значення = себе.значення[і]
                змінна нові_ключі = []
                змінна нові_значення = []
                для (й від 0 до себе.розмір) {
                    якщо (й != і) {
                        нові_ключі = нові_ключі + [себе.ключі[й]]
                        нові_значення = нові_значення + [себе.значення[й]]
                    }
                }
                себе.ключі = нові_ключі
                себе.значення = нові_значення
                себе.розмір -= 1
                повернути Деякий(значення)
            }
        }
        повернути Нічого
    }

    функція розмір(себе) -> цл64 {
        повернути себе.розмір
    }

    функція пусто(себе) -> лог {
        повернути себе.розмір == 0
    }
}

// ════════════════════════════════════════════════════════════════════
// Множина — колекція унікальних елементів
// ════════════════════════════════════════════════════════════════════

структура Множина<Т> {
    елементи: [Т],
    розмір: цл64
}

реалізація Множина<Т> {
    функція нова() -> Множина<Т> {
        повернути Множина { елементи: [], розмір: 0 }
    }

    функція додати(себе, елемент: Т) -> лог {
        якщо (себе.містить(елемент)) {
            повернути хиба
        }
        себе.елементи = себе.елементи + [елемент]
        себе.розмір += 1
        повернути істина
    }

    функція містить(себе, елемент: Т) -> лог {
        для (і від 0 до себе.розмір) {
            якщо (себе.елементи[і] == елемент) {
                повернути істина
            }
        }
        повернути хиба
    }

    функція об_єднання(себе, інша: Множина<Т>) -> Множина<Т> {
        змінна результат = Множина.нова()
        для (і від 0 до себе.розмір) {
            результат.додати(себе.елементи[і])
        }
        для (і від 0 до інша.розмір) {
            результат.додати(інша.елементи[і])
        }
        повернути результат
    }

    функція перетин(себе, інша: Множина<Т>) -> Множина<Т> {
        змінна результат = Множина.нова()
        для (і від 0 до себе.розмір) {
            якщо (інша.містить(себе.елементи[і])) {
                результат.додати(себе.елементи[і])
            }
        }
        повернути результат
    }

    функція різниця(себе, інша: Множина<Т>) -> Множина<Т> {
        змінна результат = Множина.нова()
        для (і від 0 до себе.розмір) {
            якщо (!інша.містить(себе.елементи[і])) {
                результат.додати(себе.елементи[і])
            }
        }
        повернути результат
    }
}

// ════════════════════════════════════════════════════════════════════
// Стек — LIFO
// ════════════════════════════════════════════════════════════════════

структура Стек<Т> {
    дані: [Т],
    розмір: цл64
}

реалізація Стек<Т> {
    функція новий() -> Стек<Т> {
        повернути Стек { дані: [], розмір: 0 }
    }

    функція покласти(себе, елемент: Т) {
        себе.дані = себе.дані + [елемент]
        себе.розмір += 1
    }

    функція забрати(себе) -> Опція<Т> {
        якщо (себе.розмір == 0) {
            повернути Нічого
        }
        змінна елемент = себе.дані[себе.розмір - 1]
        себе.розмір -= 1
        повернути Деякий(елемент)
    }

    функція вершина(себе) -> Опція<Т> {
        якщо (себе.розмір == 0) {
            повернути Нічого
        }
        повернути Деякий(себе.дані[себе.розмір - 1])
    }

    функція пусто(себе) -> лог {
        повернути себе.розмір == 0
    }
}

// ════════════════════════════════════════════════════════════════════
// Черга — FIFO
// ════════════════════════════════════════════════════════════════════

структура Черга<Т> {
    дані: [Т],
    розмір: цл64
}

реалізація Черга<Т> {
    функція нова() -> Черга<Т> {
        повернути Черга { дані: [], розмір: 0 }
    }

    функція додати(себе, елемент: Т) {
        себе.дані = себе.дані + [елемент]
        себе.розмір += 1
    }

    функція забрати(себе) -> Опція<Т> {
        якщо (себе.розмір == 0) {
            повернути Нічого
        }
        змінна елемент = себе.дані[0]
        змінна нові = []
        для (і від 1 до себе.розмір) {
            нові = нові + [себе.дані[і]]
        }
        себе.дані = нові
        себе.розмір -= 1
        повернути Деякий(елемент)
    }

    функція перший(себе) -> Опція<Т> {
        якщо (себе.розмір == 0) {
            повернути Нічого
        }
        повернути Деякий(себе.дані[0])
    }

    функція пусто(себе) -> лог {
        повернути себе.розмір == 0
    }
}
