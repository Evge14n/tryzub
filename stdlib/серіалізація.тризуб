// Стандартна бібліотека мови Тризуб
// Модуль: серіалізація — JSON та CSV

модуль серіалізація {
    // JSON (делегує до вбудованих)
    функція json_розібрати(рядок) {
        повернути json_розібрати(рядок)
    }

    функція json_в_рядок(значення) {
        повернути json_в_рядок(значення)
    }

    функція json_красиво(значення) {
        повернути json_в_рядок_красиво(значення)
    }

    // CSV
    функція csv_прочитати(шлях) {
        змінна зміст = файл_прочитати(шлях)
        змінна рядки = зміст.розділити("\n")
        якщо (довжина(рядки) < 2) { повернути [] }

        змінна заголовки = рядки[0].розділити(",")
        змінна результат = []

        змінна і = 1
        поки (і < довжина(рядки)) {
            змінна рядок = рядки[і]
            якщо (довжина(рядок) > 0) {
                змінна значення = рядок.розділити(",")
                змінна запис = словник()
                змінна й = 0
                поки (й < довжина(заголовки)) {
                    якщо (й < довжина(значення)) {
                        запис[заголовки[й]] = значення[й]
                    }
                    й = й + 1
                }
                результат = результат + [запис]
            }
            і = і + 1
        }
        повернути результат
    }

    функція csv_записати(шлях, дані, заголовки) {
        змінна рядки = заголовки.з_єднати(",")
        для (запис в дані) {
            змінна значення = []
            для (з в заголовки) {
                значення = значення + [запис[з]]
            }
            рядки = рядки + "\n" + значення.з_єднати(",")
        }
        файл_записати(шлях, рядки)
    }
}
