// Стандартна бібліотека: Операційна система

модуль ос {
    функція середовище(назва) {
        повернути виконати_команду("echo", [назва])
    }

    функція поточна_директорія() {
        повернути виконати_команду("cd", [])
    }

    функція шлях_з_єднати(частина1, частина2) {
        повернути частина1 + "/" + частина2
    }

    функція шлях_батьківський(шлях) {
        змінна частини = шлях.розділити("/")
        якщо (довжина(частини) <= 1) { повернути "." }
        змінна результат = ""
        змінна і = 0
        поки (і < довжина(частини) - 1) {
            якщо (і > 0) { результат = результат + "/" }
            результат = результат + частини[і]
            і = і + 1
        }
        повернути результат
    }

    функція шлях_розширення(шлях) {
        змінна частини = шлях.розділити(".")
        якщо (довжина(частини) <= 1) { повернути "" }
        повернути частини[довжина(частини) - 1]
    }

    функція шлях_ім_я(шлях) {
        змінна частини = шлях.розділити("/")
        повернути частини[довжина(частини) - 1]
    }
}
