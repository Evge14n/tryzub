// ═══════════════════════════════════════════════════════════════
// Модуль ядра: Capability-Based Security
// Замість дозволів файлів — токени можливостей
// ═══════════════════════════════════════════════════════════════

// Принцип: програма НЕ МОЖЕ зробити те, на що не отримала токен.
// Не "заборонено" — ФІЗИЧНО НЕМОЖЛИВО. Можливість просто не існує.

/// Рівень доступу
тип РівеньДоступу {
    Читання,
    Запис,
    Виконання,
    Повний
}

/// Токен можливості — незмінний, не підробляється
структура Можливість {
    ід: чс64,
    ресурс: тхт,
    рівень: РівеньДоступу,
    власник: чс32,              // PID процесу
    делегований: лог,           // Чи можна передати іншому процесу
    термін_дії: Опція<чс64>,    // Коли закінчується (мс від epoch)
    обмеження: Опція<тхт>       // Додаткові обмеження (regex шлях, порт, тощо)
}

/// Набір можливостей що дається програмі при запуску
структура НабірМожливостей {
    файлові: [Можливість],
    мережеві: [Можливість],
    апаратні: [Можливість],
    міжпроцесні: [Можливість]
}

реалізація НабірМожливостей {
    /// Запитати доступ до файлу
    функція файл(себе, шлях: тхт, рівень: РівеньДоступу) -> Результат<Можливість, тхт> {
        для (м в себе.файлові) {
            якщо (шлях_відповідає(м.ресурс, шлях) && рівень_достатній(м.рівень, рівень)) {
                повернути Успіх(м)
            }
        }
        повернути Помилка(ф"Немає можливості для {шлях} з рівнем {рівень}")
    }

    /// Запитати мережевий доступ
    функція мережа(себе, хост: тхт, порт: чс16) -> Результат<Можливість, тхт> {
        для (м в себе.мережеві) {
            якщо (м.ресурс == хост) {
                повернути Успіх(м)
            }
        }
        повернути Помилка(ф"Немає можливості для {хост}:{порт}")
    }

    /// Делегувати можливість дочірньому процесу (з обмеженнями)
    функція делегувати(себе, можливість: Можливість, дочірній_pid: чс32) -> Результат<Можливість, тхт> {
        якщо (!можливість.делегований) {
            повернути Помилка("Цю можливість не можна делегувати")
        }
        повернути Успіх(Можливість {
            ід: генерувати_ід(),
            ресурс: можливість.ресурс,
            рівень: можливість.рівень,
            власник: дочірній_pid,
            делегований: хиба,  // Дочірній не може передати далі
            термін_дії: можливість.термін_дії,
            обмеження: можливість.обмеження
        })
    }
}

/// Пісочниця — ізольоване середовище виконання
структура Пісочниця {
    можливості: НабірМожливостей,
    ліміт_пам'яті: чсрозм,
    ліміт_cpu: Відсоток,
    ліміт_мережі: чсрозм,  // байт/сек
    дозвіл_породження: лог  // Чи може створювати дочірні процеси
}

реалізація Пісочниця {
    функція нова(можливості: НабірМожливостей) -> Пісочниця {
        повернути Пісочниця {
            можливості: можливості,
            ліміт_пам'яті: 256 * 1024 * 1024,  // 256MB за замовчуванням
            ліміт_cpu: Відсоток(25),
            ліміт_мережі: 1024 * 1024,          // 1MB/s
            дозвіл_породження: хиба
        }
    }
}
