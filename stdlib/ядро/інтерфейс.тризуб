// ═══════════════════════════════════════════════════════════════
// Модуль ядра: Декларативний UI
// GPU-прискорений, 120fps, вбудований в ОС
// ═══════════════════════════════════════════════════════════════

/// Тема оформлення
тип Тема {
    Світла,
    Темна,
    Системна,
    Власна(Кольори)
}

структура Кольори {
    фон: чс32,
    текст: чс32,
    акцент: чс32,
    помилка: чс32,
    успіх: чс32
}

/// Базовий елемент UI
тип ЕлементUI {
    Текст {
        значення: тхт,
        розмір: чс16,
        колір: Опція<чс32>,
        жирний: лог
    },
    Кнопка {
        текст: тхт,
        натиск: функція(),
        вимкнена: лог
    },
    ПолеВводу {
        значення: тхт,
        підказка: тхт,
        зміна: функція(тхт)
    },
    Зображення {
        шлях: тхт,
        ширина: Опція<чс16>,
        висота: Опція<чс16>
    },
    Стовпець {
        діти: [ЕлементUI],
        відступ: чс16,
        проміжок: чс16
    },
    Рядок {
        діти: [ЕлементUI],
        відступ: чс16,
        проміжок: чс16
    },
    Сітка {
        діти: [ЕлементUI],
        колонки: чс8,
        проміжок: чс16
    },
    Список {
        елементи: [ЕлементUI],
        вибраний: Опція<чсрозм>
    },
    Прокрутка {
        дитина: ЕлементUI,
        напрямок: Напрямок
    },
    Порожній
}

тип Напрямок {
    Вертикальний,
    Горизонтальний,
    Обидва
}

/// Вікно програми
структура Вікно {
    заголовок: тхт,
    ширина: чс16,
    висота: чс16,
    вміст: ЕлементUI,
    тема: Тема,
    гарячі_клавіші: [(тхт, функція())]
}

реалізація Вікно {
    функція створити(заголовок: тхт) -> Вікно {
        повернути Вікно {
            заголовок: заголовок,
            ширина: 800,
            висота: 600,
            вміст: ЕлементUI.Порожній,
            тема: Тема.Системна,
            гарячі_клавіші: []
        }
    }

    функція з_темою(себе, тема: Тема) -> Вікно {
        себе.тема = тема
        повернути себе
    }

    функція з_розміром(себе, ш: чс16, в: чс16) -> Вікно {
        себе.ширина = ш
        себе.висота = в
        повернути себе
    }

    функція додати_клавішу(себе, комбінація: тхт, дія: функція()) {
        себе.гарячі_клавіші = себе.гарячі_клавіші + [(комбінація, дія)]
    }
}

/// GPU-рендерер
трейт Рендерер {
    функція малювати_прямокутник(себе, х: цл32, у: цл32, ш: чс16, в: чс16, колір: чс32)
    функція малювати_текст(себе, х: цл32, у: цл32, текст: тхт, розмір: чс16, колір: чс32)
    функція малювати_зображення(себе, х: цл32, у: цл32, шлях: тхт, ш: чс16, в: чс16)
    функція оновити(себе)
}
