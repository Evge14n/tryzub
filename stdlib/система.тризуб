// Клавіатура (PS/2)
// ════════════════════════════════════════════════════════════════════

стала ПОРТ_КЛАВІАТУРИ: чс16 = 0x60
стала ПОРТ_СТАНУ_КЛАВІАТУРИ: чс16 = 0x64

функція прочитати_клавішу() -> Опція<чс8> {
    змінна стан = порт_прочитати_байт(ПОРТ_СТАНУ_КЛАВІАТУРИ)
    якщо (стан & 1 != 0) {
        повернути Деякий(порт_прочитати_байт(ПОРТ_КЛАВІАТУРИ))
    }
    повернути Нічого
}

функція скан_код_в_символ(код: чс8) -> Опція<сим> {
    // Базова таблиця скан-кодів US QWERTY
    зіставити код {
        0x02 => Деякий('1'),
        0x03 => Деякий('2'),
        0x04 => Деякий('3'),
        0x05 => Деякий('4'),
        0x06 => Деякий('5'),
        0x07 => Деякий('6'),
        0x08 => Деякий('7'),
        0x09 => Деякий('8'),
        0x0A => Деякий('9'),
        0x0B => Деякий('0'),
        0x10 => Деякий('q'),
        0x11 => Деякий('w'),
        0x12 => Деякий('e'),
        0x13 => Деякий('r'),
        0x14 => Деякий('t'),
        0x15 => Деякий('y'),
        0x16 => Деякий('u'),
        0x17 => Деякий('i'),
        0x18 => Деякий('o'),
        0x19 => Деякий('p'),
        0x1C => Деякий('\n'),
        0x1E => Деякий('a'),
        0x1F => Деякий('s'),
        0x20 => Деякий('d'),
        0x21 => Деякий('f'),
        0x22 => Деякий('g'),
        0x23 => Деякий('h'),
        0x24 => Деякий('j'),
        0x25 => Деякий('k'),
        0x26 => Деякий('l'),
        0x39 => Деякий(' '),
        _ => Нічого
    }
}
