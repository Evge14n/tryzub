// ════════════════════════════════════════════════════════════════════

/// Кольори VGA текстового режиму
тип КолірVGA {
    Чорний,
    Синій,
    Зелений,
    Блакитний,
    Червоний,
    Пурпуровий,
    Коричневий,
    Сірий,
    ТемноСірий,
    ЯскравоСиній,
    ЯскравоЗелений,
    ЯскравоБлакитний,
    ЯскравоЧервоний,
    ЯскравоПурпуровий,
    Жовтий,
    Білий
}

структура VGAТекст {
    буфер: вказівник<чс16>,
    ширина: чсрозм,
    висота: чсрозм,
    стовпець: чсрозм,
    рядок: чсрозм,
    колір: чс8
}

реалізація VGAТекст {
    функція новий() -> VGAТекст {
        повернути VGAТекст {
            буфер: 0xB8000 як вказівник<чс16>,
            ширина: 80,
            висота: 25,
            стовпець: 0,
            рядок: 0,
            колір: 0x0F // білий на чорному
        }
    }

    функція очистити(себе) {
        змінна пусто = (себе.колір як чс16) << 8 | 0x20
        для (і від 0 до себе.ширина * себе.висота) {
            мінливий себе.буфер[і] = пусто
        }
        себе.стовпець = 0
        себе.рядок = 0
    }

    функція записати_символ(себе, символ: чс8) {
        якщо (символ == 0x0A) { // новий рядок
            себе.стовпець = 0
            себе.рядок += 1
        } інакше {
            змінна позиція = себе.рядок * себе.ширина + себе.стовпець
            мінливий себе.буфер[позиція] = (себе.колір як чс16) << 8 | (символ як чс16)
            себе.стовпець += 1
            якщо (себе.стовпець >= себе.ширина) {
                себе.стовпець = 0
                себе.рядок += 1
            }
        }
        якщо (себе.рядок >= себе.висота) {
            себе.прокрутити()
        }
    }

    функція записати_рядок(себе, рядок: тхт) {
        для (символ в рядок) {
            себе.записати_символ(символ як чс8)
        }
    }

    функція встановити_колір(себе, передній: КолірVGA, задній: КолірVGA) {
        себе.колір = (задній як чс8) << 4 | (передній як чс8)
    }

    функція прокрутити(себе) {
        // Зсуваємо всі рядки на один вгору
        для (р від 1 до себе.висота) {
            для (с від 0 до себе.ширина) {
                змінна звідки = р * себе.ширина + с
                змінна куди = (р - 1) * себе.ширина + с
                мінливий себе.буфер[куди] = себе.буфер[звідки]
            }
        }
        // Очищаємо останній рядок
        змінна пусто = (себе.колір як чс16) << 8 | 0x20
        для (с від 0 до себе.ширина) {
            змінна позиція = (себе.висота - 1) * себе.ширина + с
            мінливий себе.буфер[позиція] = пусто
        }
        себе.рядок = себе.висота - 1
    }
}

