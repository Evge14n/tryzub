/// Розподільник пам'яті
трейт Розподільник {
    функція виділити(себе, розмір: чсрозм, вирівнювання: чсрозм) -> Результат<вказівник<чс8>, тхт>
    функція звільнити(себе, вказівник: вказівник<чс8>, розмір: чсрозм)
    функція перевиділити(себе, вказівник: вказівник<чс8>, старий_розмір: чсрозм, новий_розмір: чсрозм) -> Результат<вказівник<чс8>, тхт>
}

/// Bump-розподільник — найшвидший, без звільнення
структура БампРозподільник {
    початок: чсрозм,
    поточний: чсрозм,
    кінець: чсрозм
}

реалізація Розподільник для БампРозподільник {
    функція виділити(себе, розмір: чсрозм, вирівнювання: чсрозм) -> Результат<вказівник<чс8>, тхт> {
        // Вирівнюємо поточний вказівник
        змінна вирівняний = (себе.поточний + вирівнювання - 1) & !(вирівнювання - 1)
        якщо (вирівняний + розмір > себе.кінець) {
            повернути Помилка("Недостатньо пам'яті")
        }
        себе.поточний = вирівняний + розмір
        повернути Успіх(вирівняний як вказівник<чс8>)
    }

    функція звільнити(себе, вказівник: вказівник<чс8>, розмір: чсрозм) {
        // Bump-розподільник не звільняє окремі блоки
    }

    функція перевиділити(себе, вказівник: вказівник<чс8>, старий_розмір: чсрозм, новий_розмір: чсрозм) -> Результат<вказівник<чс8>, тхт> {
        змінна новий = себе.виділити(новий_розмір, 8)?
        // Копіюємо дані
        пам_копіювати(новий, вказівник, старий_розмір)
        повернути Успіх(новий)
    }
}

/// Арена-розподільник — швидкий, звільняє все разом
структура АренаРозподільник {
    блоки: [вказівник<чс8>],
    поточний_блок: чсрозм,
    зміщення: чсрозм,
    розмір_блоку: чсрозм
}

реалізація АренаРозподільник {
    функція новий(розмір_блоку: чсрозм) -> АренаРозподільник {
        повернути АренаРозподільник {
            блоки: [],
            поточний_блок: 0,
            зміщення: 0,
            розмір_блоку: розмір_блоку
        }
    }

    функція очистити(себе) {
        // Звільняє всю пам'ять арени одним махом
        для (блок в себе.блоки) {
            пам_звільнити(блок, себе.розмір_блоку)
        }
        себе.блоки = []
        себе.поточний_блок = 0
        себе.зміщення = 0
    }
}

/// Пул-розподільник — для об'єктів однакового розміру
структура ПулРозподільник<Т> {
    дані: вказівник<Т>,
    вільні: [чсрозм],
    ємність: чсрозм,
    розмір_елемента: чсрозм
}

реалізація ПулРозподільник<Т> {
    функція новий(ємність: чсрозм) -> ПулРозподільник<Т> {
        змінна розмір = ємність * розмір(Т)
        змінна дані = пам_виділити(розмір) як вказівник<Т>
        змінна вільні = []
        для (і від 0 до ємність) {
            вільні = вільні + [і]
        }
        повернути ПулРозподільник {
            дані: дані,
            вільні: вільні,
            ємність: ємність,
            розмір_елемента: розмір(Т)
        }
    }

    функція виділити(себе) -> Опція<вказівник<Т>> {
        якщо (себе.вільні.довжина() == 0) {
            повернути Нічого
        }
        змінна індекс = себе.вільні.забрати()
        повернути Деякий(себе.дані + індекс * себе.розмір_елемента)
    }

    функція звільнити(себе, вказівник: вказівник<Т>) {
        змінна індекс = (вказівник - себе.дані) / себе.розмір_елемента
        себе.вільні = себе.вільні + [індекс]
    }
}

