// Стандартна бібліотека: JSON
// Модуль: json
// Серіалізація та десеріалізація JSON

// ════════════════════════════════════════════════════════════════════
// Типи даних JSON
// ════════════════════════════════════════════════════════════════════

тип JsonЗначення {
    Об_єкт([(тхт, JsonЗначення)]),
    Масив([JsonЗначення]),
    Рядок(тхт),
    Число(дрб64),
    Логічне(лог),
    Нуль
}

// ════════════════════════════════════════════════════════════════════
// Парсер JSON
// ════════════════════════════════════════════════════════════════════

функція розібрати(текст: тхт) -> Результат<JsonЗначення, тхт> {
    змінна позиція = 0
    повернути розібрати_значення(текст, позиція)
}

функція розібрати_значення(текст: тхт, позиція: цл64) -> Результат<JsonЗначення, тхт> {
    // Пропускаємо пробіли
    поки (позиція < довжина(текст) && є_пробіл(текст[позиція])) {
        позиція += 1
    }

    якщо (позиція >= довжина(текст)) {
        повернути Помилка("Несподіваний кінець JSON")
    }

    зіставити текст[позиція] {
        '"' => розібрати_рядок(текст, позиція),
        '{' => розібрати_об_єкт(текст, позиція),
        '[' => розібрати_масив(текст, позиція),
        't' => {
            якщо (текст[позиція..позиція+4] == "true") {
                повернути Успіх(JsonЗначення.Логічне(істина))
            }
            повернути Помилка("Невалідний JSON")
        },
        'f' => {
            якщо (текст[позиція..позиція+5] == "false") {
                повернути Успіх(JsonЗначення.Логічне(хиба))
            }
            повернути Помилка("Невалідний JSON")
        },
        'n' => {
            якщо (текст[позиція..позиція+4] == "null") {
                повернути Успіх(JsonЗначення.Нуль)
            }
            повернути Помилка("Невалідний JSON")
        },
        _ якщо є_цифра(текст[позиція]) || текст[позиція] == '-' => {
            розібрати_число(текст, позиція)
        },
        _ => Помилка(ф"Несподіваний символ на позиції {позиція}")
    }
}

// ════════════════════════════════════════════════════════════════════
// Серіалізація в JSON
// ════════════════════════════════════════════════════════════════════

функція в_рядок(значення: JsonЗначення) -> тхт {
    зіставити значення {
        JsonЗначення.Нуль => "null",
        JsonЗначення.Логічне(л) => якщо (л) { "true" } інакше { "false" },
        JsonЗначення.Число(н) => цілеврядок(н),
        JsonЗначення.Рядок(р) => ф"\"{р}\"",
        JsonЗначення.Масив(елементи) => {
            змінна частини = []
            для (е в елементи) {
                частини = частини + [в_рядок(е)]
            }
            ф"[{з_єднати(частини, ", ")}]"
        },
        JsonЗначення.Об_єкт(поля) => {
            змінна частини = []
            для (пара в поля) {
                змінна ключ = пара[0]
                змінна значення = пара[1]
                частини = частини + [ф"\"{ключ}\": {в_рядок(значення)}"]
            }
            ф"{{{з_єднати(частини, ", ")}}}"
        }
    }
}

функція в_рядок_красиво(значення: JsonЗначення, відступ: цл64) -> тхт {
    змінна пробіли = повторити(" ", відступ * 2)
    змінна пробіли_внутр = повторити(" ", (відступ + 1) * 2)

    зіставити значення {
        JsonЗначення.Об_єкт(поля) => {
            якщо (довжина(поля) == 0) {
                повернути "{}"
            }
            змінна частини = []
            для (пара в поля) {
                змінна ключ = пара[0]
                змінна знач = пара[1]
                частини = частини + [ф"{пробіли_внутр}\"{ключ}\": {в_рядок_красиво(знач, відступ + 1)}"]
            }
            ф"{{\n{з_єднати(частини, ",\n")}\n{пробіли}}}"
        },
        JsonЗначення.Масив(елементи) => {
            якщо (довжина(елементи) == 0) {
                повернути "[]"
            }
            змінна частини = []
            для (е в елементи) {
                частини = частини + [ф"{пробіли_внутр}{в_рядок_красиво(е, відступ + 1)}"]
            }
            ф"[\n{з_єднати(частини, ",\n")}\n{пробіли}]"
        },
        _ => в_рядок(значення)
    }
}

// ════════════════════════════════════════════════════════════════════
// Трейт для серіалізації
// ════════════════════════════════════════════════════════════════════

трейт Серіалізований {
    функція в_json(себе) -> JsonЗначення
}

трейт Десеріалізований {
    функція з_json(дані: JsonЗначення) -> Результат<себе, тхт>
}
