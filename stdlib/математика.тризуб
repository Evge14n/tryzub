// Стандартна бібліотека мови Тризуб
// Модуль: математика

модуль математика {
    // Константи
    змінна ПІ = 3.14159265358979323846
    змінна Е = 2.71828182845904523536
    змінна ТАУ = 6.28318530717958647692
    змінна ЗОЛОТИЙ_ПЕРЕТИН = 1.61803398874989484820
    змінна НЕСКІНЧЕННІСТЬ = 1.0 / 0.0
    змінна НЕ_ЧИСЛО = 0.0 / 0.0

    // Основні функції (делегують до вбудованих)
    функція синус(x) { повернути синус(x) }
    функція косинус(x) { повернути косинус(x) }
    функція корінь(x) { повернути корінь(x) }
    функція степінь(основа, показник) { повернути степінь_ф(основа, показник) }
    функція логарифм(x) { повернути логарифм(x) }

    функція абс(x) {
        якщо (x < 0) { повернути -x }
        повернути x
    }

    функція мін(а, б) {
        якщо (а < б) { повернути а }
        повернути б
    }

    функція макс(а, б) {
        якщо (а > б) { повернути а }
        повернути б
    }

    функція округлити(x) {
        змінна п = x + 0.5
        повернути п - п % 1
    }

    функція підлога(x) {
        повернути x - x % 1
    }

    функція стеля(x) {
        змінна п = підлога(x)
        якщо (x > п) { повернути п + 1 }
        повернути п
    }

    функція модуль(x) { повернути абс(x) }

    // Випадкові числа
    змінна _зерно = 12345

    функція випадкове() {
        _зерно = (_зерно * 1103515245 + 12345) % 2147483648
        повернути _зерно / 2147483648.0
    }

    функція випадкове_дробове() {
        повернути випадкове()
    }

    функція випадкове_ціле(від, до) {
        повернути від + підлога(випадкове() * (до - від + 1))
    }

    // Цілочисельна математика
    функція нсд(а, б) {
        змінна x = абс(а)
        змінна y = абс(б)
        поки (y != 0) {
            змінна з = x % y
            x = y
            y = з
        }
        повернути x
    }

    функція нск(а, б) {
        повернути абс(а * б) / нсд(а, б)
    }

    функція факторіал(n) {
        якщо (n < 0) { паніка("Факторіал визначений тільки для невід'ємних чисел") }
        якщо (n <= 1) { повернути 1 }
        змінна результат = 1
        змінна і = 2
        поки (і <= n) {
            результат = результат * і
            і = і + 1
        }
        повернути результат
    }

    функція є_простим(n) {
        якщо (n <= 1) { повернути хиба }
        якщо (n <= 3) { повернути істина }
        якщо (n % 2 == 0) { повернути хиба }
        якщо (n % 3 == 0) { повернути хиба }
        змінна і = 5
        поки (і * і <= n) {
            якщо (n % і == 0) { повернути хиба }
            якщо (n % (і + 2) == 0) { повернути хиба }
            і = і + 6
        }
        повернути істина
    }
}
