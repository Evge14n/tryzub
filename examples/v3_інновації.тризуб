// Тризуб v3.0 — Демонстрація інноваційних фіч
// Ефекти, контракти, тестування, unsafe, comptime
// ═══════════════════════════════════════════════════════════════

// ── 1. Система ефектів ──

ефект ВвідВивід {
    функція прочитати() -> тхт
    функція записати(дані: тхт)
}

ефект Мережа {
    функція отримати(url: тхт) -> тхт
}

// ── 2. Структури з контрактами ──

структура Рахунок {
    власник: тхт,
    баланс: дрб64
}

функція створити_рахунок(власник: тхт, початковий: дрб64) -> Рахунок {
    повернути Рахунок { власник: власник, баланс: початковий }
}

функція внести_на_рахунок(рах: Рахунок, сума: дрб64) -> Результат<дрб64, тхт> {
    якщо (сума <= 0.0) {
        повернути Помилка("Сума повинна бути додатною")
    }
    повернути Успіх(рах.баланс + сума)
}

функція зняти_з_рахунку(рах: Рахунок, сума: дрб64) -> Результат<дрб64, тхт> {
    якщо (сума <= 0.0) {
        повернути Помилка("Сума повинна бути додатною")
    }
    якщо (сума > рах.баланс) {
        повернути Помилка("Недостатньо коштів")
    }
    повернути Успіх(рах.баланс - сума)
}

// ── 3. Тести ──

тест "арифметика працює" {
    перевірити 2 + 2 == 4
    перевірити 10 * 5 == 50
    перевірити 100 / 4 == 25
    друк("Тест арифметики: ОК")
}

тест "рахунок працює" {
    змінна рах = створити_рахунок("Тест", 1000.0)
    внести_на_рахунок(рах, 500.0)
    друк("Тест рахунку: ОК")
}

// ── 4. Алгебраїчні типи з pattern matching ──

тип Команда {
    Допомога,
    Баланс(тхт),
    Переказ(тхт, тхт, дрб64),
    Вихід
}

функція виконати_команду(команда: Команда) -> тхт {
    зіставити команда {
        Допомога => "Доступні команди: допомога, баланс, переказ, вихід",
        Баланс(власник) => ф"Баланс {власник}: перевіряю...",
        Переказ(відправник, отримувач, сума) якщо сума > 0.0 => ф"Переказ {сума} від {відправник} до {отримувач}",
        Переказ(_, _, _) => "Помилка: сума повинна бути додатною",
        Вихід => "До побачення!"
    }
}

// ── 5. Головна функція ──

функція головна() {
    друк("═══════════════════════════════════════════")
    друк("  Тризуб v3.0 — Інноваційні можливості")
    друк("═══════════════════════════════════════════")

    // Ефекти (декларації)
    друк("\n--- Система ефектів ---")
    друк("Ефект ВвідВивід: прочитати(), записати()")
    друк("Ефект Мережа: отримати()")
    друк("Чисті функції гарантовано без побічних ефектів")

    // Контракти через перевірки
    друк("\n--- Контракти ---")
    змінна рах = створити_рахунок("Євген", 5000.0)
    друк(ф"Створено рахунок: {рах.власник}, баланс: {рах.баланс}")

    зіставити внести_на_рахунок(рах, 2000.0) {
        Успіх(б) => друк(ф"Внесено 2000. Баланс: {б}"),
        Помилка(п) => друк(ф"Помилка: {п}")
    }

    зіставити зняти_з_рахунку(рах, 1000.0) {
        Успіх(б) => друк(ф"Знято 1000. Баланс: {б}"),
        Помилка(п) => друк(ф"Помилка: {п}")
    }

    зіставити зняти_з_рахунку(рах, 99999.0) {
        Успіх(б) => друк(ф"Знято. Баланс: {б}"),
        Помилка(п) => друк(ф"Контракт: {п}")
    }

    // Pattern matching з guard та алгебраїчними типами
    друк("\n--- Команди з pattern matching ---")
    змінна команди = [
        Допомога,
        Баланс("Євген"),
        Переказ("Євген", "Олена", 500.0),
        Переказ("Іван", "Марія", -100.0),
        Вихід
    ]

    для (к в команди) {
        друк(ф"> {виконати_команду(к)}")
    }

    // Перевірки (assert)
    друк("\n--- Перевірки ---")
    перевірити 2 + 2 == 4
    перевірити 10 > 5
    перевірити 100 % 3 == 1
    друк("Всі перевірки пройшли!")

    // Unsafe блок
    друк("\n--- Небезпечний блок ---")
    небезпечний {
        друк("Виконано в небезпечному контексті")
        друк("Тут можна працювати з вказівниками напряму")
    }

    // Компчас
    друк("\n--- Компчас ---")
    компчас {
        друк("Цей код виконується на етапі компіляції")
        змінна фіб = 0
        змінна а = 0
        змінна б = 1
        для (і від 0 до 10) {
            фіб = а + б
            а = б
            б = фіб
        }
        друк(ф"Компчас Фібоначчі(10) = {а}")
    }

    // Діапазони та функціональний стиль
    друк("\n--- Функціональний стиль ---")
    змінна сума_квадратів = 0
    для (н в 1..=10) {
        якщо (н % 2 == 0) {
            сума_квадратів += н * н
        }
    }
    друк(ф"Сума квадратів парних від 1 до 10: {сума_квадратів}")

    // Факторіал через рекурсію
    друк(ф"10! = {факторіал(10)}")

    друк("\n═══════════════════════════════════════════")
    друк("✅ Все працює! Тризуб v3.0")
}

функція факторіал(н: цл64) -> цл64 {
    якщо (н <= 1) { повернути 1 }
    повернути н * факторіал(н - 1)
}
