// Демонстрація async/await — Блок 6
// все(), перегони(), потік(), чекати

функція завантажити_дані(назва) {
    час_затримка(10)
    повернути "Дані: " + назва
}

функція обчислити_суму(початок, кінець) {
    змінна сума = 0
    змінна і = початок
    поки (і <= кінець) {
        сума = сума + і
        і = і + 1
    }
    повернути сума
}

функція головна() {
    друк("═══ Async/Await у Тризуб ═══")

    // чекати — обробляє результат
    друк("")
    друк("--- Чекати ---")
    змінна р = чекати 42
    друк("чекати 42 =")
    друк(р)

    // все() — паралельне виконання
    друк("")
    друк("--- все() — паралельне виконання ---")
    функція ф1() { повернути завантажити_дані("А") }
    функція ф2() { повернути завантажити_дані("Б") }
    функція ф3() { повернути завантажити_дані("В") }

    змінна результати = все([ф1, ф2, ф3])
    для (р в результати) {
        друк(р)
    }

    // перегони() — перша відповідь
    друк("")
    друк("--- перегони() — перший результат ---")
    функція швидка() { повернути "Швидка відповідь!" }
    функція повільна() { повернути "Повільна" }

    змінна переможець = перегони([швидка, повільна])
    друк(переможець)

    // потік() — виконання в потоці
    друк("")
    друк("--- потік() ---")
    функція задача() { повернути обчислити_суму(1, 100) }
    змінна сума = потік(задача)
    друк("Сума 1..100 (потік):")
    друк(сума)

    друк("")
    друк("Async/Await працює!")
}
