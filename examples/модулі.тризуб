// Демонстрація модульної системи Тризуб
// Блок 2: імпорти, namespace ізоляція, stdlib

// ── Визначення власних модулів ──

модуль геометрія {
    змінна ПІ = 3.14159265358979

    функція площа_кола(радіус) {
        повернути ПІ * радіус * радіус
    }

    функція периметр_кола(радіус) {
        повернути 2 * ПІ * радіус
    }

    функція площа_прямокутника(ширина, висота) {
        повернути ширина * висота
    }

    функція гіпотенуза(а, б) {
        повернути корінь(а * а + б * б)
    }
}

модуль конвертер {
    функція цельсій_фаренгейт(ц) {
        повернути ц * 9 / 5 + 32
    }

    функція фаренгейт_цельсій(ф) {
        повернути (ф - 32) * 5 / 9
    }

    функція км_милі(км) {
        повернути км * 0.621371
    }

    функція кг_фунти(кг) {
        повернути кг * 2.20462
    }
}

// ── Selective import ──
імпорт геометрія { площа_кола, гіпотенуза }

// ── Alias import ──
імпорт конвертер як к

функція головна() {
    друк("═══ Модульна система Тризуб ═══")
    друк("")

    // Доступ через повне ім'я модуля
    друк("Площа прямокутника 5×3:")
    друк(геометрія.площа_прямокутника(5, 3))
    друк("Периметр кола r=10:")
    друк(геометрія.периметр_кола(10))

    // Доступ через selective import (без префіксу)
    друк("Площа кола r=5:")
    друк(площа_кола(5))
    друк("Гіпотенуза 3,4:")
    друк(гіпотенуза(3, 4))

    // Доступ через аліас
    друк("")
    друк("100°C у Фаренгейтах:")
    друк(к.цельсій_фаренгейт(100))
    друк("10 км у милях:")
    друк(к.км_милі(10))

    // Namespace ізоляція
    друк("")
    друк("ПІ з модуля геометрія:")
    друк(геометрія.ПІ)

    друк("")
    друк("Модульна система працює!")
}
