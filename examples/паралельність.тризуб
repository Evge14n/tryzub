// Обчислення числа Пі методом Монте-Карло
// Послідовна версія

функція головна() {
    друк("Обчислення числа Пі методом Монте-Карло")
    друк("========================================")

    змінна кількість_точок = 100000
    змінна точки_в_колі = 0

    змінна стан = 12345
    для (і в 0..кількість_точок) {
        стан = (стан * 1103515245 + 12345) % 2147483648
        змінна х = (стан % 10000) як дрб64 / 5000.0 - 1.0
        стан = (стан * 1103515245 + 12345) % 2147483648
        змінна у = (стан % 10000) як дрб64 / 5000.0 - 1.0

        якщо (х * х + у * у <= 1.0) {
            точки_в_колі += 1
        }
    }

    змінна пі = 4.0 * (точки_в_колі як дрб64) / (кількість_точок як дрб64)
    змінна похибка = абс(пі - ПІ)

    друк(ф"Кількість точок: {кількість_точок}")
    друк(ф"Точки в колі: {точки_в_колі}")
    друк(ф"Обчислене Пі: {пі}")
    друк(ф"Реальне Пі:   {ПІ}")
    друк(ф"Похибка:      {похибка}")

    друк("")
    друк("Лічильник (демонстрація циклу):")
    змінна лічильник = 0
    для (і в 0..10) {
        для (й в 0..1000) {
            лічильник += 1
        }
    }
    друк(ф"  Лічильник після 10 x 1000 ітерацій: {лічильник}")
}
