функція додати_числа(а: ціле, б: ціле) -> ціле {
    повернути а + б
}

структура Користувач {
    ім_я: тхт,
    вік: ціле
}

функція головна() {
    змінна результат = додати_числа(10, 20)
    друк("10 + 20 =")
    друк(результат)

    змінна к = Користувач { ім_я: "Євген", вік: 25 }
    друк(к.ім_я)
    друк(к.вік)

    змінна х = 42
    друк("Type inference: х =")
    друк(х)
    друк("Тип: " + тип_значення(х))
}
