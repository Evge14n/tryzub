функція головна() {
    друк("🇺🇦 Вітаємо в мові програмування Тризуб!")
    друк("=====================================")
    друк("Автор: *******")
    друк("Створено: 06.04.2025")
    друк("")
    
    // Тест змінних
    змінна ім'я = "Євген"
    змінна вік = 25
    друк("Привіт, " + ім'я + "!")
    друк("Вам " + цілеврядок(вік) + " років")
    друк("")
    
    // Тест арифметики
    друк("Арифметичні операції:")
    змінна a = 10
    змінна b = 3
    друк("  " + цілеврядок(a) + " + " + цілеврядок(b) + " = " + цілеврядок(a + b))
    друк("  " + цілеврядок(a) + " - " + цілеврядок(b) + " = " + цілеврядок(a - b))
    друк("  " + цілеврядок(a) + " * " + цілеврядок(b) + " = " + цілеврядок(a * b))
    друк("  " + цілеврядок(a) + " / " + цілеврядок(b) + " = " + цілеврядок(a / b))
    друк("")
    
    // Тест умовних операторів
    друк("Умовні оператори:")
    якщо (вік >= 18) {
        друк("  Ви повнолітній")
    } інакше {
        друк("  Ви неповнолітній")
    }
    друк("")
    
    // Тест циклів
    друк("Цикл від 1 до 5:")
    для (i від 1 до 6) {
        друк("  Число: " + цілеврядок(i))
    }
    друк("")
    
    друк("✅ Всі тести пройшли успішно!")
}
