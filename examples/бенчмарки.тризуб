// Бенчмарки Тризуб VM

функція фіб(n) {
    якщо (n <= 1) { повернути n }
    повернути фіб(n - 1) + фіб(n - 2)
}

функція бенчмарк_фібоначчі() {
    змінна старт = час_зараз()
    змінна р = фіб(25)
    змінна час = час_зараз() - старт
    друк("Fibonacci(25) = " + ціле_в_рядок(р) + " — " + ціле_в_рядок(час) + "мс")
}

функція бенчмарк_сортування() {
    змінна старт = час_зараз()
    змінна масив = []
    змінна і = 0
    поки (і < 1000) {
        масив = масив + [1000 - і]
        і = і + 1
    }
    змінна відсортований = масив.сортувати()
    змінна час = час_зараз() - старт
    друк("Сортування 1K = " + ціле_в_рядок(час) + "мс")
}

функція бенчмарк_рядки() {
    змінна старт = час_зараз()
    змінна с = ""
    змінна і = 0
    поки (і < 1000) {
        с = с + "а"
        і = і + 1
    }
    змінна час = час_зараз() - старт
    друк("Конкатенація 1K рядків = " + ціле_в_рядок(час) + "мс (довжина: " + ціле_в_рядок(довжина(с)) + ")")
}

функція бенчмарк_словники() {
    змінна старт = час_зараз()
    змінна д = словник()
    змінна і = 0
    поки (і < 1000) {
        д[ціле_в_рядок(і)] = і * і
        і = і + 1
    }
    змінна час = час_зараз() - старт
    друк("Словник 1K inserts = " + ціле_в_рядок(час) + "мс")
}

функція головна() {
    друк("═══ Бенчмарки Тризуб VM ═══")
    друк("")
    бенчмарк_фібоначчі()
    бенчмарк_сортування()
    бенчмарк_рядки()
    бенчмарк_словники()
    друк("")
    друк("Готово!")
}
