// Тест модульної системи

// Визначаємо простий модуль прямо в файлі
модуль утиліти {
    функція подвоїти(x) {
        повернути x * 2
    }

    функція привітати(ім_я) {
        повернути "Привіт, " + ім_я + "!"
    }

    змінна ВЕРСІЯ = "1.0.0"
}

функція головна() {
    // Доступ через крапку
    друк(утиліти.подвоїти(21))
    друк(утиліти.привітати("Тризуб"))
    друк(утиліти.ВЕРСІЯ)
}
