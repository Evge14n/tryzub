// Тризуб — Системне програмування
// Демонстрація: пряма пам'ять, inline assembly, FFI

функція головна() {
    друк("=== Пряме керування пам'яттю ===")
    стала блок = виділити_пам'ять(256)
    друк(ф"Виділено 256 байт: 0x{блок}")

    // Запис та читання байтів
    для і в 0..10 {
        записати_байт(блок + і, і * 10)
    }
    змінна сума = 0
    для і в 0..10 {
        сума = сума + прочитати_байт(блок + і)
    }
    друк(ф"Сума байтів 0..9: {сума}")

    // 64-бітні слова
    записати_слово(блок + 64, 1234567890)
    друк(ф"Слово: {прочитати_слово(блок + 64)}")

    // memset + memcpy
    заповнити_пам'ять(блок + 128, 0xFF, 16)
    друк(ф"Перший байт після memset: {прочитати_байт(блок + 128)}")

    звільнити_пам'ять(блок)
    друк("Пам'ять звільнено")

    друк("")
    друк("=== Inline Assembly (x86_64) ===")

    // Реальні x86_64 інструкції — не заглушки
    стала число = asm_виконати("mov rax, 42\nret")
    друк(ф"mov rax, 42 → {число}")

    стала обчислення = asm_виконати("mov rax, 100\nsub rax, 58\nret")
    друк(ф"100 - 58 → {обчислення}")

    стала біти = asm_виконати("mov rax, 0xFF00\nshr rax, 8\nret")
    друк(ф"0xFF00 >> 8 → {біти}")

    стала тактів = asm_виконати("rdtsc\nshl rdx, 32\nor rax, rdx\nret")
    друк(ф"CPU timestamp: {тактів}")

    друк("")
    друк("=== Системна інформація ===")
    друк(ф"Розмір вказівника: {розмір_вказівника()} байт")
}
