функція площа_кола(р: дрб64) -> дрб64 {
    повернути 3.14159265 * р ** 2
}

функція площа_прямокутника(ш: дрб64, вис: дрб64) -> дрб64 {
    повернути ш * вис
}

функція площа_трикутника(а: дрб64, б: дрб64, ц: дрб64) -> дрб64 {
    змінна п = (а + б + ц) / 2.0
    повернути (п * (п - а) * (п - б) * (п - ц)) ** 0.5
}

функція поділити(а: дрб64, б: дрб64) -> Результат {
    якщо (б == 0.0) {
        повернути Помилка("Ділення на нуль")
    }
    повернути Успіх(а / б)
}

функція головна() {
    друк("=== Pattern Matching ===")

    друк(ф"Коло (р=5): площа = {площа_кола(5.0)}")
    друк(ф"Прямокутник 4x7: площа = {площа_прямокутника(4.0, 7.0)}")
    друк(ф"Трикутник 3-4-5: площа = {площа_трикутника(3.0, 4.0, 5.0)}")

    друк("\n=== Опція ===")
    змінна значення = Деякий(42)
    зіставити значення {
        Деякий(н) якщо н > 100 => друк("Велике число!"),
        Деякий(н) => друк(ф"Отримано: {н}"),
        Нічого => друк("Нічого немає")
    }

    друк("\n=== Результат ===")
    зіставити поділити(10.0, 3.0) {
        Успіх(р) => друк(ф"10 / 3 = {р}"),
        Помилка(п) => друк(ф"Помилка: {п}")
    }

    зіставити поділити(10.0, 0.0) {
        Успіх(р) => друк(ф"Результат: {р}"),
        Помилка(п) => друк(ф"Помилка: {п}")
    }

    друк("\n=== Guard Clauses ===")
    змінна оцінка = 85
    зіставити Деякий(оцінка) {
        Деякий(о) якщо о >= 90 => друк("Відмінно"),
        Деякий(о) якщо о >= 70 => друк("Добре"),
        Деякий(о) якщо о >= 50 => друк("Задовільно"),
        Деякий(о) => друк("Незадовільно"),
        Нічого => друк("Немає оцінки")
    }

    друк("\n=== Все працює! ===")
}
