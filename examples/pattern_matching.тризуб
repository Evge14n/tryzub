// Алгебраїчний тип — геометричні фігури
тип Фігура {
    Коло(дрб64),
    Прямокутник(дрб64, дрб64),
    Трикутник(дрб64, дрб64, дрб64)
}

функція площа(ф: Фігура) -> дрб64 {
    зіставити ф {
        Коло(р) => 3.14159265 * р ** 2,
        Прямокутник(ш, в) => ш * в,
        Трикутник(а, б, в) => {
            змінна п = (а + б + в) / 2.0
            (п * (п - а) * (п - б) * (п - в)) ** 0.5
        }
    }
}

функція описати(ф: Фігура) -> тхт {
    зіставити ф {
        Коло(р) => ф"Коло з радіусом {р}",
        Прямокутник(ш, в) якщо ш == в => ф"Квадрат зі стороною {ш}",
        Прямокутник(ш, в) => ф"Прямокутник {ш}x{в}",
        Трикутник(а, б, в) якщо а == б && б == в => ф"Рівносторонній трикутник зі стороною {а}",
        Трикутник(а, б, в) => ф"Трикутник ({а}, {б}, {в})"
    }
}

// Результат та обробка помилок
функція поділити(а: дрб64, б: дрб64) -> Результат<дрб64, тхт> {
    якщо (б == 0.0) {
        повернути Помилка("Ділення на нуль")
    }
    повернути Успіх(а / б)
}

функція головна() {
    // Фігури
    змінна фігури = [
        Коло(5.0),
        Прямокутник(4.0, 4.0),
        Прямокутник(3.0, 7.0),
        Трикутник(3.0, 4.0, 5.0),
        Трикутник(6.0, 6.0, 6.0)
    ]

    друк("=== Фігури ===")
    для (ф в фігури) {
        друк(ф"{описати(ф)} — площа: {площа(ф)}")
    }

    // Опція
    друк("\n=== Опція ===")
    змінна значення = Деякий(42)
    зіставити значення {
        Деякий(н) якщо н > 100 => друк("Велике число!"),
        Деякий(н) => друк(ф"Отримано: {н}"),
        Нічого => друк("Нічого немає")
    }

    // Результат
    друк("\n=== Результат ===")
    зіставити поділити(10.0, 3.0) {
        Успіх(р) => друк(ф"10 / 3 = {р}"),
        Помилка(п) => друк(ф"Помилка: {п}")
    }

    зіставити поділити(10.0, 0.0) {
        Успіх(р) => друк(ф"Результат: {р}"),
        Помилка(п) => друк(ф"Помилка: {п}")
    }
}
