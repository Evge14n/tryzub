// Повний веб-додаток з SQLite, шаблонами та JWT
// Це демонстрація архітектури повного додатку
// Для реального запуску потрібен веб-сервер

функція головна() {
    друк("=== Тризуб Web — Повний додаток (демо) ===")
    друк("")
    друк("Архітектура додатку 'Магазин на Тризуб':")
    друк("")
    друк("База даних (SQLite):")
    друк("  товари: назва, ціна, опис")
    друк("  юзери:  email, пароль, імя")
    друк("")
    друк("Ендпоінти:")
    друк("  GET  /              — Головна сторінка (HTML з шаблоном)")
    друк("  GET  /api/товари    — JSON список товарів")
    друк("  POST /api/реєстрація — Реєстрація (email, пароль, імя)")
    друк("  POST /api/вхід      — Авторизація (JWT токен)")
    друк("")

    друк("Приклад товарів:")
    змінна товари = [
        словник("назва", "Ноутбук", "ціна", 25000.0, "опис", "Потужний ноутбук для роботи"),
        словник("назва", "Монітор", "ціна", 12000.0, "опис", "27 дюймів, 4K"),
        словник("назва", "Клавіатура", "ціна", 2500.0, "опис", "Механічна, Cherry MX")
    ]

    для (т в товари) {
        друк(ф"  {т}")
    }

    друк("")
    друк(ф"Всього товарів: {довжина(товари)}")
    друк("")

    змінна json = json_в_рядок(товари)
    друк("JSON відповідь /api/товари:")
    друк(ф"  {json}")

    друк("")
    друк("Для запуску повного додатку з веб-сервером на порті 3000")
    друк("запустіть examples/сервер.тризуб окремо.")
}
