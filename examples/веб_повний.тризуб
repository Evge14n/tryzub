// Повний веб-додаток з SQLite, шаблонами та JWT
// Запуск: tryzub запустити examples/веб_повний.тризуб

друк("=== Тризуб Web — Повний додаток ===")

// Ініціалізуємо БД
бд_відкрити("магазин.db")
бд_створити_таблицю("товари", #{"назва" -> "тхт", "ціна" -> "дрб64", "опис" -> "тхт"})
бд_створити_таблицю("юзери", #{"email" -> "тхт", "пароль" -> "тхт", "імя" -> "тхт"})

// Наповнюємо даними
якщо бд_кількість("товари") == 0 {
    бд_створити("товари", #{"назва" -> "Ноутбук", "ціна" -> 25000.0, "опис" -> "Потужний ноутбук для роботи"})
    бд_створити("товари", #{"назва" -> "Монітор", "ціна" -> 12000.0, "опис" -> "27 дюймів, 4K"})
    бд_створити("товари", #{"назва" -> "Клавіатура", "ціна" -> 2500.0, "опис" -> "Механічна, Cherry MX"})
    друк("  Додано 3 товари")
}

// Веб-сервер
веб_сервер(3000)

// Головна
веб_отримати("/", |з| {
    стала товари = бд_всі("товари")
    стала html = шаблон_рядок("<html><head><meta charset='utf-8'><title>Магазин</title>
    <style>body{font-family:sans-serif;max-width:900px;margin:40px auto;padding:0 20px}
    .card{background:#f5f5f5;padding:20px;border-radius:8px;margin:15px 0}
    h1{color:#0057b7}.price{color:#e74c3c;font-size:1.3em;font-weight:bold}
    .btn{background:#0057b7;color:white;border:none;padding:10px 20px;border-radius:5px;cursor:pointer}</style>
    </head><body><h1>Магазин на Тризуб</h1>
    <p>Товарів: {кількість}</p>
    {для товар в товари}
    <div class='card'><h3>{товар.назва}</h3><p>{товар.опис}</p>
    <span class='price'>{товар.ціна} грн</span></div>
    {/для}
    <hr><p><a href='/api/товари'>JSON API</a> | <a href='/реєстрація'>Реєстрація</a></p>
    </body></html>", #{"товари" -> товари, "кількість" -> бд_кількість("товари")})
    веб_html(html)
})

// API
веб_отримати("/api/товари", |з| {
    веб_json(#{"товари" -> бд_всі("товари"), "кількість" -> бд_кількість("товари")})
})

// Реєстрація
веб_надіслати("/api/реєстрація", |з| {
    стала email = з["тіло"]["email"]
    стала пароль = з["тіло"]["пароль"]
    стала імя = з["тіло"]["імя"]

    стала хеш = авт_хешувати(пароль)
    стала юзер = бд_створити("юзери", #{"email" -> email, "пароль" -> хеш, "імя" -> імя})

    стала токен = авт_створити_токен(#{"ід" -> юзер["ід"], "email" -> email})
    веб_json(#{"токен" -> токен, "юзер" -> імя})
})

// Вхід
веб_надіслати("/api/вхід", |з| {
    стала email = з["тіло"]["email"]
    стала пароль = з["тіло"]["пароль"]

    стала юзери = бд_запит("юзери", #{"email" -> email})
    якщо довжина(юзери) == 0 {
        повернути веб_помилка(401, "Невірний email або пароль")
    }

    стала юзер = юзери[0]
    якщо !авт_перевірити(пароль, юзер["пароль"]) {
        повернути веб_помилка(401, "Невірний email або пароль")
    }

    стала токен = авт_створити_токен(#{"ід" -> юзер["ід"], "email" -> email})
    веб_json(#{"токен" -> токен})
})

друк("\nЗапускаю магазин...")
веб_запустити()
