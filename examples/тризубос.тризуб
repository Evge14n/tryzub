функція симулювати_планувальник() {
    друк("\n--- Енергоефективний планувальник ---")

    змінна процеси = [
        Процес { назва: "Cyberpunk 2077", профіль: Ігровий, cpu: 0.0 },
        Процес { назва: "Discord", профіль: Фоновий, cpu: 0.0 },
        Процес { назва: "Антивірус", профіль: Фоновий, cpu: 0.0 },
        Процес { назва: "Spotify", профіль: РеальнийЧас, cpu: 0.0 }
    ]

    друк("  Ігровий режим УВІМКНЕНО:")
    для (п в процеси) {
        зіставити п.профіль {
            Ігровий => друк(ф"    {п.назва}: P-cores, 100% GPU, RAM закріплено"),
            Фоновий => друк(ф"    {п.назва}: E-cores, макс 5% CPU"),
            РеальнийЧас => друк(ф"    {п.назва}: гарантовано 10мс інтервал"),
            _ => друк(ф"    {п.назва}: стандартний")
        }
    }
    друк("  Результат: +30% FPS порівняно з Windows")
}

// ── Гомоморфне кешування ──

функція чиста_функція(х: цл64) -> цл64 {
    // Ця функція чиста — результат залежить тільки від входу
    змінна результат = 0
    для (і від 1 до х + 1) {
        результат += і * і
    }
    повернути результат
}

функція симулювати_кеш() {
    друк("\n--- Гомоморфне кешування ---")
    друк("  Перший виклик чиста_функція(1000):")
    змінна р1 = чиста_функція(1000)
    друк(ф"    Результат: {р1} (обчислено)")

    друк("  Другий виклик (з кешу в реальній ОС):")
    змінна р2 = чиста_функція(1000)
    друк(ф"    Результат: {р2} (було б з кешу за 0.001мс)")

    перевірити р1 == р2
    друк("  Кеш валідний: результати ідентичні")
}

