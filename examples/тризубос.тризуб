// ── Персистентна пам'ять ──

структура СтанСистеми {
    час_запуску: цл64,
    кількість_запусків: цл64,
    відкриті_програми: [тхт],
    останній_користувач: тхт
}

функція симулювати_персистентність() {
    друк("--- Персистентна пам'ять ---")
    // В реальній ОС це зберігається між перезавантаженнями
    змінна стан = СтанСистеми {
        час_запуску: 1711410000,
        кількість_запусків: 47,
        відкриті_програми: ["Редактор", "Браузер", "Термінал"],
        останній_користувач: "Євген"
    }
    друк(ф"Запуск #{стан.кількість_запусків}")
    друк(ф"Користувач: {стан.останній_користувач}")
    друк(ф"Відкриті програми: {стан.відкриті_програми}")
    друк("Стан відновлено за 0.5с — все на місці!")
}

// ── Capability Security ──

тип РівеньДоступу {
    Читання,
    Запис,
    Мережа,
    Апаратний
}

структура Можливість {
    ресурс: тхт,
    делегований: лог
}

функція перевірити_доступ(можливості: [Можливість], ресурс: тхт) -> Результат<тхт, тхт> {
    для (м в можливості) {
        якщо (м.ресурс == ресурс) {
            повернути Успіх(ф"Доступ дозволено до {ресурс}")
        }
    }
    повернути Помилка(ф"ВІДМОВЛЕНО: немає можливості для {ресурс}")
}

функція симулювати_безпеку() {
    друк("\n--- Capability Security ---")
    змінна можливості = [
        Можливість { ресурс: "/документи", делегований: хиба },
        Можливість { ресурс: "api.com", делегований: істина }
    ]

    змінна запити = ["/документи", "api.com", "/система/ядро", "malware.com"]
    для (запит в запити) {
        зіставити перевірити_доступ(можливості, запит) {
            Успіх(повід) => друк(ф"  ✓ {повід}"),
            Помилка(повід) => друк(ф"  ✗ {повід}")
        }
    }
}

