функція фіб(n) {
    якщо (n <= 1) {
        повернути n
    }
    повернути фіб(n - 1) + фіб(n - 2)
}

функція сума_до(n) {
    змінна с = 0
    змінна і = 0
    поки (і < n) {
        с = с + і
        і = і + 1
    }
    повернути с
}

функція головна() {
    друк("Бенчмарк Cranelift:")
    друк("фіб(40):")
    друк(фіб(40))
    друк("сума(1..1000000):")
    друк(сума_до(1000000))
}
