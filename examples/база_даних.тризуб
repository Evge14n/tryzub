// Робота з SQLite базою даних у Тризуб
// Запуск: тризуб запустити examples/база_даних.тризуб

функція головна() {
    друк("=== Тризуб SQLite ORM ===")
    друк("")

    бд_відкрити("приклад.db")

    бд_створити_таблицю("товари", словник(
        "назва", "тхт",
        "ціна", "дрб64",
        "кількість", "цл64",
        "категорія", "тхт"
    ))

    стала ноутбук = бд_створити("товари", словник(
        "назва", "Ноутбук ASUS",
        "ціна", 25000.0,
        "кількість", 15,
        "категорія", "Електроніка"
    ))
    друк(ф"Створено товар: {ноутбук}")

    стала монітор = бд_створити("товари", словник(
        "назва", "Монітор LG 27''",
        "ціна", 12000.0,
        "кількість", 30,
        "категорія", "Електроніка"
    ))

    стала клавіатура = бд_створити("товари", словник(
        "назва", "Механічна клавіатура",
        "ціна", 2500.0,
        "кількість", 50,
        "категорія", "Периферія"
    ))

    стала мишка = бд_створити("товари", словник(
        "назва", "Ігрова мишка",
        "ціна", 1800.0,
        "кількість", 40,
        "категорія", "Периферія"
    ))

    стала кількість = бд_кількість("товари")
    друк(ф"\nВсього товарів: {кількість}")

    стала знайдений = бд_знайти("товари", 1)
    друк(ф"\nТовар #1: {знайдений}")

    друк("\n--- Всі товари ---")
    стала всі = бд_всі("товари")
    для (товар в всі) {
        друк(ф"  {товар}")
    }

    друк("\n--- Електроніка ---")
    стала електроніка = бд_запит("товари", словник("категорія", "Електроніка"))
    для (т в електроніка) {
        друк(ф"  {т}")
    }

    бд_оновити("товари", 1, словник("ціна", 23000.0))
    стала оновлений = бд_знайти("товари", 1)
    друк(ф"\nОновлена ціна: {оновлений}")

    бд_видалити("товари", 4)
    стала після_видалення = бд_кількість("товари")
    друк(ф"\nПісля видалення: {після_видалення} товарів")

    друк("\n--- Raw SQL ---")
    стала дорогі = бд_sql("SELECT назва, ціна FROM товари WHERE ціна > ?1 ORDER BY ціна DESC", 5000)
    для (т в дорогі) {
        друк(ф"  {т}")
    }

    друк("\nГотово!")
}
