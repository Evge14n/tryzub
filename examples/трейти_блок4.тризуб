// Демонстрація трейтів — Блок 4
// Визначення, реалізація, default methods, operator overloading

// ── Трейт з default method ──
трейт Порівнянне {
    функція менше(себе, інше: Порівнянне) -> лог

    функція більше_або_рівне(себе, інше: Порівнянне) -> лог {
        повернути !себе.менше(інше)
    }
}

структура Число {
    значення: ціле
}

реалізація Порівнянне для Число {
    функція менше(себе, інше) {
        повернути себе.значення < інше.значення
    }
}

// ── Operator overloading ──
структура Вектор2Д {
    х: ціле,
    у: ціле
}

реалізація Вектор2Д {
    функція додати(себе, інший) {
        повернути Вектор2Д { х: себе.х + інший.х, у: себе.у + інший.у }
    }

    функція відняти(себе, інший) {
        повернути Вектор2Д { х: себе.х - інший.х, у: себе.у - інший.у }
    }

    функція довжина(себе) {
        повернути корінь(себе.х * себе.х + себе.у * себе.у)
    }
}

// ── Трейт для опису ──
трейт Описуваний {
    функція опис(себе) -> тхт
}

структура Коло {
    радіус: ціле
}

реалізація Описуваний для Коло {
    функція опис(себе) {
        повернути "Коло з радіусом " + ціле_в_рядок(себе.радіус)
    }
}

структура Квадрат {
    сторона: ціле
}

реалізація Описуваний для Квадрат {
    функція опис(себе) {
        повернути "Квадрат зі стороною " + ціле_в_рядок(себе.сторона)
    }
}

функція головна() {
    друк("═══ Трейти у Тризуб ═══")

    // Default methods
    друк("")
    друк("--- Default methods ---")
    змінна а = Число { значення: 10 }
    змінна б = Число { значення: 3 }
    друк("10 < 3?")
    друк(а.менше(б))
    друк("10 >= 3? (default method)")
    друк(а.більше_або_рівне(б))

    // Operator overloading
    друк("")
    друк("--- Operator overloading ---")
    змінна в1 = Вектор2Д { х: 1, у: 2 }
    змінна в2 = Вектор2Д { х: 3, у: 4 }
    змінна сума = в1 + в2
    друк("(1,2) + (3,4) =")
    друк(сума.х)
    друк(сума.у)

    змінна різниця = в2 - в1
    друк("(3,4) - (1,2) =")
    друк(різниця.х)
    друк(різниця.у)

    // Trait implementations
    друк("")
    друк("--- Trait implementations ---")
    змінна к = Коло { радіус: 5 }
    друк(к.опис())
    змінна кв = Квадрат { сторона: 7 }
    друк(кв.опис())

    друк("")
    друк("Трейти працюють!")
}
