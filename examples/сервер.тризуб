функція обробник_головна(з: тхт) -> тхт {
    повернути веб_html("<html><head><meta charset='utf-8'></head><body><h1>Тризуб Web</h1><p>Сервер працює!</p></body></html>")
}

функція обробник_апі(з: тхт) -> тхт {
    повернути веб_html("<h1>API працює</h1>")
}

функція головна() {
    веб_сервер(3000)
    веб_отримати("/", обробник_головна)
    веб_отримати("/api", обробник_апі)
    веб_запустити()
}
