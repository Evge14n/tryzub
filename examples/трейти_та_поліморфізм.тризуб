// Трейти та поліморфізм на Тризуб
// Pattern matching, guard-умови, Результат та Опція

тип ДвоОп {
    Додавання(дрб64, дрб64),
    Множення(дрб64, дрб64),
    Ділення(дрб64, дрб64)
}

функція обчислити(оп: ДвоОп) -> Результат<дрб64, тхт> {
    зіставити оп {
        Додавання(а, б) => Успіх(а + б),
        Множення(а, б) => Успіх(а * б),
        Ділення(а, б) якщо б == 0.0 => Помилка("Ділення на нуль!"),
        Ділення(а, б) => Успіх(а / б)
    }
}

функція описати_оп(оп: ДвоОп) -> тхт {
    зіставити оп {
        Додавання(а, б) => ф"{а} + {б}",
        Множення(а, б) => ф"{а} * {б}",
        Ділення(а, б) => ф"{а} / {б}"
    }
}

функція оцінка(бал: цл64) -> тхт {
    зіставити бал {
        _ якщо бал >= 90 => "Відмінно (A)",
        _ якщо бал >= 80 => "Добре (B)",
        _ якщо бал >= 70 => "Задовільно (C)",
        _ якщо бал >= 60 => "Достатньо (D)",
        _ => "Незадовільно (F)"
    }
}

функція поділити(а: дрб64, б: дрб64) -> Результат<дрб64, тхт> {
    якщо (б == 0.0) {
        повернути Помилка("Ділення на нуль")
    }
    повернути Успіх(а / б)
}

функція головна() {
    друк("=== Операції з pattern matching ===")
    змінна операції = [
        Додавання(10.0, 32.0),
        Множення(6.0, 7.0),
        Ділення(100.0, 3.0),
        Ділення(42.0, 0.0)
    ]

    для (оп в операції) {
        змінна опис = описати_оп(оп)
        зіставити обчислити(оп) {
            Успіх(р) => друк(ф"  {опис} = {р}"),
            Помилка(п) => друк(ф"  {опис} => {п}")
        }
    }

    друк("\n=== Оцінки з guard-умовами ===")
    змінна бали = [95, 82, 73, 65, 45]
    для (бал в бали) {
        друк(ф"  {бал} балів -> {оцінка(бал)}")
    }

    друк("\n=== Опція ===")
    змінна значення = Деякий(42)
    зіставити значення {
        Деякий(н) якщо н > 100 => друк("  Велике число!"),
        Деякий(н) => друк(ф"  Отримано: {н}"),
        Нічого => друк("  Нічого немає")
    }

    змінна пусте = Нічого
    зіставити пусте {
        Деякий(н) => друк(ф"  Знайдено: {н}"),
        Нічого => друк("  Нічого не знайдено")
    }

    друк("\n=== Результат ===")
    зіставити поділити(10.0, 3.0) {
        Успіх(р) => друк(ф"  10 / 3 = {р}"),
        Помилка(п) => друк(ф"  Помилка: {п}")
    }

    зіставити поділити(10.0, 0.0) {
        Успіх(р) => друк(ф"  Результат: {р}"),
        Помилка(п) => друк(ф"  Помилка: {п}")
    }

    друк("\n=== Банківський рахунок (словник) ===")
    змінна рахунок = словник("власник", "Євген", "баланс", 10000.0, "ставка", 5.5)
    друк(ф"  Власник: Євген, Баланс: 10000 грн")

    змінна баланс = 10000.0
    баланс = баланс + 5000.0
    друк(ф"  Внесено 5000. Баланс: {баланс} грн")

    баланс = баланс - 3000.0
    друк(ф"  Знято 3000. Баланс: {баланс} грн")
}
