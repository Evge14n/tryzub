// Приклад: Трейти та поліморфізм
// Мова Тризуб v2.0

// Трейт для відображення
трейт Показуваний {
    функція показати(себе) -> тхт
}

// Трейт для порівняння
трейт Порівнюваний {
    функція порівняти(себе, інший: себе) -> цл32

    функція менше(себе, інший: себе) -> лог {
        повернути себе.порівняти(інший) < 0
    }

    функція більше(себе, інший: себе) -> лог {
        повернути себе.порівняти(інший) > 0
    }

    функція рівне(себе, інший: себе) -> лог {
        повернути себе.порівняти(інший) == 0
    }
}

// Трейт для обчислення площі
трейт МаєПлощу {
    функція площа(себе) -> дрб64

    функція більше_за(себе, інший: себе) -> лог {
        повернути себе.площа() > інший.площа()
    }
}

// Структура "Точка"
структура Точка {
    х: дрб64,
    у: дрб64
}

реалізація Показуваний для Точка {
    функція показати(себе) -> тхт {
        повернути ф"Точка({себе.х}, {себе.у})"
    }
}

реалізація Точка {
    функція нова(х: дрб64, у: дрб64) -> Точка {
        повернути Точка { х: х, у: у }
    }

    функція відстань(себе, інша: Точка) -> дрб64 {
        змінна дх = себе.х - інша.х
        змінна ду = себе.у - інша.у
        повернути (дх ** 2 + ду ** 2) ** 0.5
    }
}

// Структура "Банківський рахунок" з трейтами
структура Рахунок {
    власник: тхт,
    баланс: дрб64,
    відсоткова_ставка: дрб64
}

трейт Банківський {
    функція внести(себе, сума: дрб64) -> Результат<дрб64, тхт>
    функція зняти(себе, сума: дрб64) -> Результат<дрб64, тхт>
    функція баланс(себе) -> дрб64
}

реалізація Банківський для Рахунок {
    функція внести(себе, сума: дрб64) -> Результат<дрб64, тхт> {
        якщо (сума <= 0.0) {
            повернути Помилка("Сума повинна бути додатною")
        }
        себе.баланс += сума
        повернути Успіх(себе.баланс)
    }

    функція зняти(себе, сума: дрб64) -> Результат<дрб64, тхт> {
        якщо (сума <= 0.0) {
            повернути Помилка("Сума повинна бути додатною")
        }
        якщо (сума > себе.баланс) {
            повернути Помилка(ф"Недостатньо коштів. Баланс: {себе.баланс}")
        }
        себе.баланс -= сума
        повернути Успіх(себе.баланс)
    }

    функція баланс(себе) -> дрб64 {
        повернути себе.баланс
    }
}

реалізація Показуваний для Рахунок {
    функція показати(себе) -> тхт {
        повернути ф"Рахунок {себе.власник}: {себе.баланс} грн ({себе.відсоткова_ставка}%)"
    }
}

функція головна() {
    // Точки
    друк("=== Точки ===")
    змінна а = Точка.нова(3.0, 4.0)
    змінна б = Точка.нова(0.0, 0.0)
    друк(а.показати())
    друк(ф"Відстань від {а.показати()} до {б.показати()}: {а.відстань(б)}")

    // Банківські рахунки
    друк("\n=== Банк ===")
    змінна рахунок = Рахунок {
        власник: "Євген",
        баланс: 10000.0,
        відсоткова_ставка: 5.5
    }

    друк(рахунок.показати())

    зіставити рахунок.внести(5000.0) {
        Успіх(баланс) => друк(ф"Внесено. Новий баланс: {баланс} грн"),
        Помилка(повід) => друк(ф"Помилка: {повід}")
    }

    зіставити рахунок.зняти(20000.0) {
        Успіх(баланс) => друк(ф"Знято. Новий баланс: {баланс} грн"),
        Помилка(повід) => друк(ф"Помилка: {повід}")
    }

    зіставити рахунок.зняти(3000.0) {
        Успіх(баланс) => друк(ф"Знято. Новий баланс: {баланс} грн"),
        Помилка(повід) => друк(ф"Помилка: {повід}")
    }
}
