структура Вектор2Д {
    х: ціле,
    у: ціле
}

реалізація Вектор2Д {
    функція додати(себе, інший) {
        повернути Вектор2Д { х: себе.х + інший.х, у: себе.у + інший.у }
    }

    функція відняти(себе, інший) {
        повернути Вектор2Д { х: себе.х - інший.х, у: себе.у - інший.у }
    }

    функція довжина(себе) {
        повернути корінь(себе.х * себе.х + себе.у * себе.у)
    }
}

функція головна() {
    змінна а = Вектор2Д { х: 3, у: 4 }
    змінна б = Вектор2Д { х: 1, у: 2 }

    змінна сума = а + б
    друк("(3,4) + (1,2) =")
    друк(сума.х)
    друк(сума.у)

    змінна різниця = а - б
    друк("(3,4) - (1,2) =")
    друк(різниця.х)
    друк(різниця.у)

    друк("Довжина (3,4) =")
    друк(а.довжина())
}
