// Тимчасова точка входу для тестування логіки через VM
функція головна() {
    друк("═══════════════════════════════════════")
    друк("  ТризубОС v0.1.0 — Тест ядра")
    друк("  Українська операційна система")
    друк("═══════════════════════════════════════")
    друк("")
    друк("[ОК] Ініціалізація VGA текстового режиму")
    друк("[ОК] Ініціалізація розподільника пам'яті")
    друк("[ОК] Ініціалізація клавіатури")
    друк("")
    друк("Система готова!")
    друк("")

    // Тест обробки команд
    змінна команди = ["допомога", "інфо", "невідома", "пам'ять"]
    для (команда в команди) {
        друк("> " + команда)
        зіставити команда {
            "допомога" => {
                друк("  допомога  — показати довідку")
                друк("  інфо      — інформація про систему")
                друк("  очистити  — очистити екран")
                друк("  вимкнути  — вимкнути систему")
            },
            "інфо" => {
                друк("  ТризубОС v0.1.0")
                друк("  Мова: Тризуб v2.0")
                друк("  Архітектура: x86_64")
            },
            "пам'ять" => {
                друк("  Всього: 3 MB")
                друк("  Вільно: 3 MB")
            },
            _ => друк("  Невідома команда!")
        }
        друк("")
    }
