// ═══════════════════════════════════════════════════════════════
// Мінімальне ядро ОС на мові Тризуб
// Демонстрація bare-metal програмування українською
// ═══════════════════════════════════════════════════════════════

// Без стандартної бібліотеки — ми на bare-metal
// #![no_std]
// #![no_main]

// імпорт система::VGAТекст
// імпорт система::КолірVGA
// імпорт система::БампРозподільник

// ═══════════════════════════════════════════════════════════════
// Глобальний стан ядра
// ═══════════════════════════════════════════════════════════════

стала ВЕРСІЯ_ЯДРА: тхт = "0.1.0"
стала НАЗВА_ОС: тхт = "ТризубОС"

структура Ядро {
    екран: VGAТекст,
    розподільник: БампРозподільник,
    запущено: лог
}

реалізація Ядро {
    функція створити() -> Ядро {
        повернути Ядро {
            екран: VGAТекст.створити(),
            розподільник: БампРозподільник {
                початок: 0x100000,    // 1MB — початок вільної пам'яті
                поточний: 0x100000,
                кінець: 0x400000      // 4MB — кінець доступної пам'яті
            },
            запущено: хиба
        }
    }

    функція ініціалізувати(себе) {
        себе.запущено = істина
        себе.екран.очистити()

        // Заголовок
        себе.екран.встановити_колір(КолірVGA.ЯскравоБлакитний, КолірVGA.Чорний)
        себе.екран.записати_рядок("════════════════════════════════════════\n")
        себе.екран.встановити_колір(КолірVGA.Жовтий, КолірVGA.Чорний)
        себе.екран.записати_рядок("  ТризубОС v0.1.0\n")
        себе.екран.встановити_колір(КолірVGA.ЯскравоБлакитний, КолірVGA.Чорний)
        себе.екран.записати_рядок("  Українська операційна система\n")
        себе.екран.записати_рядок("════════════════════════════════════════\n\n")

        // Інформація про систему
        себе.екран.встановити_колір(КолірVGA.Зелений, КолірVGA.Чорний)
        себе.екран.записати_рядок("[ОК] ")
        себе.екран.встановити_колір(КолірVGA.Білий, КолірVGA.Чорний)
        себе.екран.записати_рядок("Ініціалізація VGA текстового режиму\n")

        себе.екран.встановити_колір(КолірVGA.Зелений, КолірVGA.Чорний)
        себе.екран.записати_рядок("[ОК] ")
        себе.екран.встановити_колір(КолірVGA.Білий, КолірVGA.Чорний)
        себе.екран.записати_рядок("Ініціалізація розподільника пам'яті (3MB)\n")

        себе.екран.встановити_колір(КолірVGA.Зелений, КолірVGA.Чорний)
        себе.екран.записати_рядок("[ОК] ")
        себе.екран.встановити_колір(КолірVGA.Білий, КолірVGA.Чорний)
        себе.екран.записати_рядок("Ініціалізація клавіатури PS/2\n")

        себе.екран.записати_рядок("\n")
        себе.екран.встановити_колір(КолірVGA.ЯскравоЗелений, КолірVGA.Чорний)
        себе.екран.записати_рядок("Система готова. Введіть команду:\n")
        себе.екран.встановити_колір(КолірVGA.Сірий, КолірVGA.Чорний)
        себе.екран.записати_рядок("> ")
    }

    функція обробити_команду(себе, команда: тхт) {
        зіставити команда {
            "допомога" => {
                себе.екран.записати_рядок("Доступні команди:\n")
                себе.екран.записати_рядок("  допомога  — показати цю довідку\n")
                себе.екран.записати_рядок("  інфо      — інформація про систему\n")
                себе.екран.записати_рядок("  пам'ять   — стан пам'яті\n")
                себе.екран.записати_рядок("  очистити  — очистити екран\n")
                себе.екран.записати_рядок("  вимкнути  — вимкнути систему\n")
            },
            "інфо" => {
                себе.екран.встановити_колір(КолірVGA.Жовтий, КолірVGA.Чорний)
                себе.екран.записати_рядок("ТризубОС v0.1.0\n")
                себе.екран.встановити_колір(КолірVGA.Білий, КолірVGA.Чорний)
                себе.екран.записати_рядок("Мова: Тризуб v2.0\n")
                себе.екран.записати_рядок("Архітектура: x86_64\n")
                себе.екран.записати_рядок("Автор: Мартинюк Євген\n")
            },
            "пам'ять" => {
                змінна використано = себе.розподільник.поточний - себе.розподільник.початок
                змінна всього = себе.розподільник.кінець - себе.розподільник.початок
                себе.екран.записати_рядок("Пам'ять:\n")
                себе.екран.записати_рядок("  Всього:       3 MB\n")
                себе.екран.записати_рядок("  Використано:  ")
                // друк(використано / 1024)
                себе.екран.записати_рядок(" KB\n")
            },
            "очистити" => {
                себе.ініціалізувати()
            },
            "вимкнути" => {
                себе.екран.встановити_колір(КолірVGA.Жовтий, КолірVGA.Чорний)
                себе.екран.записати_рядок("Вимикаю систему...\n")
                // ACPI shutdown
                порт_записати_байт(0x604, 0x2000)
                себе.запущено = хиба
            },
            _ => {
                себе.екран.встановити_колір(КолірVGA.ЯскравоЧервоний, КолірVGA.Чорний)
                себе.екран.записати_рядок("Невідома команда. Введіть 'допомога'\n")
                себе.екран.встановити_колір(КолірVGA.Білий, КолірVGA.Чорний)
            }
        }
        себе.екран.встановити_колір(КолірVGA.Сірий, КолірVGA.Чорний)
        себе.екран.записати_рядок("> ")
    }
}

