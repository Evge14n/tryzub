// Демонстрація генериків у Тризуб
// Блок 3: параметричний поліморфізм

// Генерична функція — працює з будь-яким типом
функція макс<Т>(а, б) {
    якщо а > б { повернути а }
    повернути б
}

функція мін<Т>(а, б) {
    якщо а < б { повернути а }
    повернути б
}

функція ідентичність<Т>(х) {
    повернути х
}

функція обміняти<А, Б>(а, б) {
    повернути [б, а]
}

// Генерична структура
структура Пара<А, Б> {
    перше: А,
    друге: Б
}

структура Коробка<Т> {
    вміст: Т,
    мітка: тхт
}

функція головна() {
    друк("═══ Генерики у Тризуб ═══")
    друк("")

    // Генеричні функції з різними типами
    друк("макс(3, 7) = ")
    друк(макс(3, 7))
    друк("макс(3.14, 2.71) = ")
    друк(макс(3.14, 2.71))
    друк("макс(100, 200) = ")
    друк(макс(100, 200))

    друк("")
    друк("мін(10, 5) = ")
    друк(мін(10, 5))

    // Ідентичність
    друк("")
    друк("ідентичність(42) = ")
    друк(ідентичність(42))
    друк("ідентичність(\"текст\") = ")
    друк(ідентичність("текст"))

    // Обмін
    друк("")
    змінна р = обміняти(1, "один")
    друк("обміняти(1, \"один\") = ")
    друк(р)

    // Генеричні структури
    друк("")
    змінна пара = Пара { перше: 42, друге: "відповідь" }
    друк("Пара<ціле, рядок>:")
    друк(пара.перше)
    друк(пара.друге)

    змінна коробка = Коробка { вміст: [1, 2, 3], мітка: "числа" }
    друк("")
    друк("Коробка<масив>:")
    друк(коробка.мітка)
    друк(коробка.вміст)

    друк("")
    друк("Генерики працюють!")
}
