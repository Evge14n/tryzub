функція сторінка_головна(з: тхт) -> тхт {
    стала html = файл_прочитати("examples/сайт/головна.html")
    повернути веб_html(html)
}

функція сторінка_про(з: тхт) -> тхт {
    стала html = файл_прочитати("examples/сайт/про.html")
    повернути веб_html(html)
}

функція апі_статус(з: тхт) -> тхт {
    стала час = часова_мітка()
    повернути веб_html(ф"працює, час: {час}")
}

функція головна() {
    веб_сервер(8080)
    веб_отримати("/", сторінка_головна)
    веб_отримати("/about", сторінка_про)
    веб_отримати("/api/status", апі_статус)
    веб_статичні("examples/сайт/статичні")
    веб_запустити()
}
