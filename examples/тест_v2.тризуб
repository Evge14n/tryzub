// Тест всіх основних конструкцій Тризуб v2.0

тип Колір {
    Червоний,
    Зелений,
    Синій
}

функція назва_кольору(к: Колір) -> тхт {
    зіставити к {
        Червоний => "червоний",
        Зелений => "зелений",
        Синій => "синій"
    }
}

функція факторіал(н: цл64) -> цл64 {
    якщо (н <= 1) {
        повернути 1
    }
    повернути н * факторіал(н - 1)
}

функція головна() {
    друк("Тризуб v2.0 — Тест")
    друк("═══════════════════════")

    // Змінні та арифметика
    змінна а = 10
    змінна б = 20
    друк(а + б)

    // Рядки
    змінна привіт = "Привіт, " + "Тризуб!"
    друк(привіт)

    // Умови
    якщо (а < б) {
        друк("а менше б")
    } інакше {
        друк("а >= б")
    }

    // Цикл for
    змінна сума = 0
    для (і від 1 до 11) {
        сума += і
    }
    друк(сума)

    // For-in з діапазоном
    для (і в 1..=5) {
        друк(і)
    }

    // Enum та pattern matching
    змінна колір = Червоний
    друк(назва_кольору(колір))

    змінна зел = Зелений
    зіставити зел {
        Червоний => друк("це червоний"),
        Зелений => друк("це зелений"),
        _ => друк("інший колір")
    }

    // Опція
    змінна є = Деякий(42)
    зіставити є {
        Деякий(н) => друк(н),
        Нічого => друк("нічого")
    }

    змінна порожнє = Нічого
    зіставити порожнє {
        Деякий(н) => друк(н),
        Нічого => друк("нічого")
    }

    // Результат
    змінна ок = Успіх(100)
    зіставити ок {
        Успіх(значення) => друк(значення),
        Помилка(повід) => друк(повід)
    }

    // Рекурсія
    друк(факторіал(10))

    // Масиви та for-in
    змінна імена = ["Олег", "Марія", "Дмитро"]
    для (ім в імена) {
        друк(ім)
    }

    // Вкладений match з guard
    змінна оцінка = 85
    зіставити оцінка {
        _ якщо оцінка >= 90 => друк("Відмінно"),
        _ якщо оцінка >= 70 => друк("Добре"),
        _ => друк("Задовільно")
    }

    друк("═══════════════════════")
    друк("✅ Всі тести пройшли!")
}
