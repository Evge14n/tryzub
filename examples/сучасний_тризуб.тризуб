// Демонстрація всіх нових можливостей Тризуб v2.0
// Це програма, яка показує алгебраїчні типи, pattern matching,
// трейти, pipeline, лямбди, інтерполяцію рядків та діапазони

// ═══════════════════════════════════════════
// 1. Алгебраїчні типи
// ═══════════════════════════════════════════

тип Результат_ОП<Т> {
    Ок(Т),
    Відмова(тхт)
}

тип Вираз {
    Число(дрб64),
    Додавання(дрб64, дрб64),
    Множення(дрб64, дрб64),
    Ділення(дрб64, дрб64)
}

// ═══════════════════════════════════════════
// 2. Pattern Matching з guard умовами
// ═══════════════════════════════════════════

функція обчислити(вираз: Вираз) -> Результат<дрб64, тхт> {
    зіставити вираз {
        Число(н) => Успіх(н),
        Додавання(а, б) => Успіх(а + б),
        Множення(а, б) => Успіх(а * б),
        Ділення(а, б) якщо б == 0.0 => Помилка("Ділення на нуль!"),
        Ділення(а, б) => Успіх(а / б)
    }
}

функція оцінка(бал: цл32) -> тхт {
    зіставити бал {
        _ якщо бал >= 90 => "Відмінно (A)",
        _ якщо бал >= 80 => "Добре (B)",
        _ якщо бал >= 70 => "Задовільно (C)",
        _ якщо бал >= 60 => "Достатньо (D)",
        _ => "Незадовільно (F)"
    }
}

// ═══════════════════════════════════════════
// 3. Трейти
// ═══════════════════════════════════════════

трейт Описуваний {
    функція опис(себе) -> тхт
}

структура Студент {
    ім_я: тхт,
    курс: цл32,
    середній_бал: дрб64
}

реалізація Описуваний для Студент {
    функція опис(себе) -> тхт {
        повернути ф"{себе.ім_я}, {себе.курс} курс, бал: {себе.середній_бал}"
    }
}

структура Предмет {
    назва: тхт,
    кредити: цл32
}

реалізація Описуваний для Предмет {
    функція опис(себе) -> тхт {
        повернути ф"{себе.назва} ({себе.кредити} кредитів)"
    }
}

// ═══════════════════════════════════════════
// 4. Головна функція з усіма фічами
// ═══════════════════════════════════════════

функція головна() {
    друк("Тризуб v2.0 — Демонстрація можливостей")
    друк("═══════════════════════════════════════════")

    // Інтерполяція рядків
    друк("")
    друк("📝 Інтерполяція рядків:")
    змінна мова = "Тризуб"
    змінна версія = 2
    друк(ф"  Ви використовуєте {мова} v{версія}.0")
    друк(ф"  2 + 2 = {2 + 2}")

    // Діапазони та for-in
    друк("")
    друк("🔢 Діапазони:")
    змінна сума = 0
    для (і в 1..=100) {
        сума += і
    }
    друк(ф"  Сума від 1 до 100 = {сума}")

    // Pattern Matching
    друк("")
    друк("🎯 Pattern Matching:")
    змінна вирази = [
        Число(42.0),
        Додавання(10.0, 32.0),
        Множення(6.0, 7.0),
        Ділення(100.0, 3.0),
        Ділення(42.0, 0.0)
    ]

    для (в в вирази) {
        зіставити обчислити(в) {
            Успіх(р) => друк(ф"  Результат: {р}"),
            Помилка(п) => друк(ф"  Помилка: {п}")
        }
    }

    // Оцінки з guard
    друк("")
    друк("📊 Оцінки:")
    змінна бали = [95, 82, 73, 65, 45]
    для (бал в бали) {
        друк(ф"  {бал} балів → {оцінка(бал)}")
    }

    // Трейти
    друк("")
    друк("🎓 Трейти:")
    змінна студент = Студент {
        ім_я: "Олександра",
        курс: 3,
        середній_бал: 92.5
    }
    друк(ф"  Студент: {студент.опис()}")

    змінна предмет = Предмет {
        назва: "Алгоритми та структури даних",
        кредити: 5
    }
    друк(ф"  Предмет: {предмет.опис()}")

    // Опція та Результат
    друк("")
    друк("📦 Опція та Результат:")
    змінна значення = Деякий(42)
    зіставити значення {
        Деякий(н) => друк(ф"  Знайдено: {н}"),
        Нічого => друк("  Не знайдено")
    }

    змінна пусте = Нічого
    зіставити пусте {
        Деякий(н) => друк(ф"  Знайдено: {н}"),
        Нічого => друк("  Нічого не знайдено — і це нормально!")
    }

    // Масиви з for-in
    друк("")
    друк("📋 Масиви:")
    змінна імена = ["Євген", "Олена", "Дмитро", "Марія", "Андрій"]
    для (ім_я в імена) {
        друк(ф"  Привіт, {ім_я}!")
    }

    // Числа Фібоначчі
    друк("")
    друк("🔢 Фібоначчі:")
    змінна а = 0
    змінна б = 1
    змінна фіб_рядок = ""
    для (і в 0..15) {
        фіб_рядок = фіб_рядок + цілеврядок(а)
        якщо (і < 14) {
            фіб_рядок = фіб_рядок + ", "
        }
        змінна тимч = а + б
        а = б
        б = тимч
    }
    друк(ф"  {фіб_рядок}")

    друк("")
    друк("═══════════════════════════════════════════")
    друк("✅ Все працює! Тризуб v2.0 🇺🇦")
}
