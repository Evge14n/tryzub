// Допоміжні функції
функція факторіал(н: цл64) -> цл64 {
    якщо (н <= 1) { повернути 1 }
    повернути н * факторіал(н - 1)
}

тип Колір {
    Червоний,
    Зелений,
    Синій
}

функція назва_кольору(к: Колір) -> тхт {
    зіставити к {
        Червоний => "червоний",
        Зелений => "зелений",
        Синій => "синій"
    }
}

