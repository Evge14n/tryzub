// Тести мови Тризуб — запуск через: тризуб тестувати тести_мови.тризуб

// Допоміжні функції
функція факторіал(н: цл64) -> цл64 {
    якщо (н <= 1) { повернути 1 }
    повернути н * факторіал(н - 1)
}

тип Колір {
    Червоний,
    Зелений,
    Синій
}

функція назва_кольору(к: Колір) -> тхт {
    зіставити к {
        Червоний => "червоний",
        Зелений => "зелений",
        Синій => "синій"
    }
}

// ── Тести ──

тест "арифметика" {
    перевірити 2 + 2 == 4
    перевірити 10 - 3 == 7
    перевірити 6 * 7 == 42
    перевірити 100 / 4 == 25
    перевірити 10 % 3 == 1
    перевірити 2 ** 10 == 1024
}

тест "порівняння" {
    перевірити 5 > 3
    перевірити 3 < 5
    перевірити 5 >= 5
    перевірити 5 <= 5
    перевірити 5 == 5
    перевірити 5 != 4
}

тест "логічні оператори" {
    перевірити істина && істина
    перевірити істина || хиба
    перевірити !(хиба)
    перевірити !(1 == 2)
}

тест "рядки" {
    змінна а = "Привіт"
    змінна б = ", світ!"
    перевірити а + б == "Привіт, світ!"
}

тест "рекурсія — факторіал" {
    перевірити факторіал(0) == 1
    перевірити факторіал(1) == 1
    перевірити факторіал(5) == 120
    перевірити факторіал(10) == 3628800
}

тест "enum та pattern matching" {
    перевірити назва_кольору(Червоний) == "червоний"
    перевірити назва_кольору(Зелений) == "зелений"
    перевірити назва_кольору(Синій) == "синій"
}

тест "Опція — Деякий" {
    змінна значення = Деякий(42)
    змінна результат = зіставити значення {
        Деякий(н) => н,
        Нічого => 0
    }
    перевірити результат == 42
}

тест "Опція — Нічого" {
    змінна значення = Нічого
    змінна результат = зіставити значення {
        Деякий(н) => н,
        Нічого => -1
    }
    перевірити результат == -1
}

тест "Результат — Успіх" {
    змінна р = Успіх(100)
    змінна отримано = зіставити р {
        Успіх(значення) => значення,
        Помилка(повід) => 0
    }
    перевірити отримано == 100
}

тест "цикл for — сума" {
    змінна сума = 0
    для (і від 1 до 11) {
        сума += і
    }
    перевірити сума == 55
}

тест "цикл for-in діапазон" {
    змінна сума = 0
    для (і в 1..=10) {
        сума += і
    }
    перевірити сума == 55
}

тест "match з guard" {
    змінна х = 85
    змінна оцінка = зіставити х {
        _ якщо х >= 90 => "A",
        _ якщо х >= 70 => "B",
        _ => "C"
    }
    перевірити оцінка == "B"
}

тест "побітові зсуви" {
    перевірити 1 << 3 == 8
    перевірити 16 >> 2 == 4
    перевірити 5 ^ 3 == 6
}

тест "неявний return" {
    змінна результат = факторіал(5)
    перевірити результат == 120
}
