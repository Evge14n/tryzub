}

тест "контракти вимагає" {
    функція безпечне_ділення(а: дрб64, б: дрб64) -> дрб64
        вимагає { б != 0.0 }
    {
        повернути а / б
    }
    перевірити безпечне_ділення(10.0, 2.0) == 5.0
}

тест "контракти вимагає відхиляє" {
    функція тільки_додатнє(х: цл64) -> цл64
        вимагає { х > 0 }
    {
        повернути х * 2
    }
    змінна зловлено = хиба
    спробувати {
        тільки_додатнє(-5)
    } зловити помилка {
        зловлено = істина
    }
    перевірити зловлено
}

