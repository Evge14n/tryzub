тест "вкладений match" {
    тип Форма {
        Коло(дрб64),
        Квадрат(дрб64)
    }

    функція площа(ф: Форма) -> дрб64 {
        зіставити ф {
            Коло(р) => 3.14 * р * р,
            Квадрат(с) => с * с
        }
    }

    перевірити площа(Квадрат(5.0)) == 25.0
}

