// Банківська система на Тризуб
// Використовує словники для зберігання даних рахунків

функція створити_рахунок(номер: тхт, власник: тхт, баланс: дрб64, валюта: тхт) -> словник {
    повернути словник("номер", номер, "власник", власник, "баланс", баланс, "валюта", валюта)
}

функція показати_рахунок(р: словник) {
    друк("  Рахунок: " + р.отримати("номер") + " | " + р.отримати("власник") + " | " + р.отримати("баланс") як тхт + " " + р.отримати("валюта"))
}

функція головна() {
    друк("Система управління банківськими рахунками")
    друк("=========================================")

    змінна рахунки = []

    змінна р1 = створити_рахунок("UA1000001", "Петро Іваненко", 5000.0, "UAH")
    змінна р2 = створити_рахунок("UA1000002", "Марія Коваленко", 10000.0, "UAH")
    змінна р3 = створити_рахунок("UA1000003", "Олег Шевченко", 2500.0, "UAH")

    рахунки = [р1, р2, р3]

    друк("\n--- Початкові рахунки ---")
    для (р в рахунки) {
        показати_рахунок(р)
    }

    // Поповнення
    змінна баланс1 = р1.отримати("баланс") як дрб64
    баланс1 = баланс1 + 1500.0
    р1 = словник("номер", "UA1000001", "власник", "Петро Іваненко", "баланс", баланс1, "валюта", "UAH")
    друк("\nРахунок UA1000001 поповнено на 1500.0 UAH")

    // Зняття
    змінна баланс2 = р2.отримати("баланс") як дрб64
    якщо (2000.0 <= баланс2) {
        баланс2 = баланс2 - 2000.0
        р2 = словник("номер", "UA1000002", "власник", "Марія Коваленко", "баланс", баланс2, "валюта", "UAH")
        друк("З рахунку UA1000002 знято 2000.0 UAH")
    }

    // Переказ
    змінна сума_переказу = 1000.0
    баланс1 = р1.отримати("баланс") як дрб64
    змінна баланс3 = р3.отримати("баланс") як дрб64
    якщо (сума_переказу <= баланс1) {
        баланс1 = баланс1 - сума_переказу
        баланс3 = баланс3 + сума_переказу
        р1 = словник("номер", "UA1000001", "власник", "Петро Іваненко", "баланс", баланс1, "валюта", "UAH")
        р3 = словник("номер", "UA1000003", "власник", "Олег Шевченко", "баланс", баланс3, "валюта", "UAH")
        друк("Переказ 1000.0 UAH з UA1000001 на UA1000003")
    }

    рахунки = [р1, р2, р3]

    друк("\n--- Рахунки після операцій ---")
    для (р в рахунки) {
        показати_рахунок(р)
    }

    // Спроба зняти більше ніж є
    друк("\n--- Спроба неправильних операцій ---")
    баланс3 = р3.отримати("баланс") як дрб64
    якщо (10000.0 > баланс3) {
        друк("Недостатньо коштів на рахунку UA1000003 для зняття 10000.0 UAH")
    }
}
