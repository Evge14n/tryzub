// Веб-сервер на Тризуб
// Це демонстрація API веб-фреймворку
// Для реального запуску: тризуб запустити examples/сервер.тризуб

функція головна() {
    друк("=== Тризуб Web — демонстрація API ===")
    друк("")
    друк("Цей приклад показує структуру веб-сервера на Тризуб.")
    друк("Для запуску реального сервера використовуйте examples/сервер.тризуб")
    друк("")
    друк("Доступні ендпоінти:")
    друк("  GET  /             — Головна HTML-сторінка")
    друк("  GET  /api/привіт   — JSON привітання")
    друк("  GET  /api/час      — Поточний час")
    друк("  POST /api/луна     — Ехо-сервер")
    друк("  GET  /api/товари   — Список товарів")
    друк("  GET  /api/товар/1  — Товар за ID")
    друк("")

    змінна товари = [
        словник("ід", 1, "назва", "Ноутбук", "ціна", 25000, "валюта", "грн"),
        словник("ід", 2, "назва", "Монітор", "ціна", 12000, "валюта", "грн"),
        словник("ід", 3, "назва", "Клавіатура", "ціна", 2500, "валюта", "грн")
    ]

    друк("Приклад даних товарів:")
    для (т в товари) {
        друк(ф"  {т}")
    }

    друк("")
    стала зараз = час_зараз()
    друк(ф"Поточний час (мс): {зараз}")
    друк("")
    друк("Для запуску сервера на порті 3000 запустіть окремо.")
}
