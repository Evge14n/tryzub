// Приклад веб-сервера на Тризуб
// Запуск: tryzub запустити examples/веб_сервер.тризуб

// Ініціалізуємо сервер на порті 3000
веб_сервер(3000)

// Головна сторінка
веб_отримати("/", |запит| {
    веб_html("<html><head><meta charset='utf-8'><title>Тризуб Web</title>
    <style>
        body { font-family: sans-serif; max-width: 800px; margin: 50px auto; padding: 0 20px; }
        h1 { color: #0057b7; }
        .card { background: #f5f5f5; padding: 20px; border-radius: 8px; margin: 15px 0; }
        a { color: #0057b7; }
        code { background: #e0e0e0; padding: 2px 6px; border-radius: 3px; }
    </style></head><body>
    <h1>Тризуб Web</h1>
    <p>Сучасний веб-фреймворк українською мовою програмування</p>
    <div class='card'>
        <h3>API ендпоінти:</h3>
        <ul>
            <li><a href='/api/привіт'>GET /api/привіт</a> — JSON привітання</li>
            <li><a href='/api/час'>GET /api/час</a> — поточний час</li>
            <li><code>POST /api/луна</code> — ехо-сервер (повертає тіло запиту)</li>
            <li><a href='/api/товари'>GET /api/товари</a> — список товарів</li>
            <li><a href='/api/товар/1'>GET /api/товар/{ід}</a> — товар за ID</li>
        </ul>
    </div>
    </body></html>")
})

// JSON API — привітання
веб_отримати("/api/привіт", |запит| {
    веб_json(#{"повідомлення" -> "Привіт зі світу Тризуб!", "версія" -> "4.1.0"})
})

// JSON API — поточний час
веб_отримати("/api/час", |запит| {
    стала зараз = час_зараз()
    веб_json(#{"час_мс" -> зараз, "статус" -> "працює"})
})

// POST ендпоінт — ехо
веб_надіслати("/api/луна", |запит| {
    стала тіло = запит["тіло"]
    веб_json(#{
        "отримано" -> тіло,
        "метод" -> "POST",
        "повідомлення" -> "Ваші дані отримані!"
    })
})

// Список товарів
веб_отримати("/api/товари", |запит| {
    стала товари = [
        #{"ід" -> 1, "назва" -> "Ноутбук", "ціна" -> 25000, "валюта" -> "грн"},
        #{"ід" -> 2, "назва" -> "Монітор", "ціна" -> 12000, "валюта" -> "грн"},
        #{"ід" -> 3, "назва" -> "Клавіатура", "ціна" -> 2500, "валюта" -> "грн"}
    ]
    веб_json(#{"товари" -> товари, "кількість" -> довжина(товари)})
})

// Товар за ID (параметр у шляху)
веб_отримати("/api/товар/{ід}", |запит| {
    стала товари = [
        #{"ід" -> 1, "назва" -> "Ноутбук", "ціна" -> 25000},
        #{"ід" -> 2, "назва" -> "Монітор", "ціна" -> 12000},
        #{"ід" -> 3, "назва" -> "Клавіатура", "ціна" -> 2500}
    ]

    // Поки що повертаємо перший товар
    веб_json(#{"товар" -> товари[0], "статус" -> "знайдено"})
})

// Сторінка помилки
веб_отримати("/помилка", |запит| {
    веб_помилка(500, "Це тестова помилка")
})

// Перенаправлення
веб_отримати("/на-головну", |запит| {
    веб_перенаправити("/")
})

// Запускаємо сервер!
друк("Запускаю веб-сервер...")
веб_запустити()
